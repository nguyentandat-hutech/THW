@{
    ViewData["Title"] = "Đặt Hàng Thành Công";
    var orderId = ViewBag.OrderId;
}

<div class="container my-5 py-4 animate-fade-in text-center">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 shadow-sm rounded-4 p-5 bg-white">
                <!-- Icon checkmark động -->
                <div class="mb-4 d-inline-flex align-items-center justify-content-center bg-light text-success rounded-circle" style="width: 100px; height: 100px; font-size: 4rem;">
                    <i class="fa-solid fa-circle-check text-success animate-fade-in"></i>
                </div>

                <h2 class="text-success fw-bold mb-3">Đặt Hàng Thành Công!</h2>
                <p class="text-secondary mb-4">Cảm ơn quý khách đã tin tưởng và lựa chọn thực phẩm hữu cơ sạch tại <strong>GreenFood</strong>. Đơn hàng của bạn đang được nhân viên chuẩn bị đóng gói và giao sớm nhất.</p>

                <!-- Box hiển thị mã đơn hàng nổi bật -->
                <div class="p-4 bg-light rounded-4 border border-light mb-4 text-center">
                    <span class="text-muted d-block small mb-1">MÃ ĐƠN HÀNG CỦA BẠN</span>
                    <h3 class="fw-extrabold text-success m-0" style="letter-spacing: 1px;">#@orderId</h3>
                    <small class="text-muted d-block mt-2">Vui lòng lưu lại mã này để tiện đối soát thông tin khi nhận hàng.</small>
                </div>

                <p class="text-muted mb-4 small"><i class="fa-solid fa-clock text-success me-1"></i> Bộ phận CSKH sẽ liên hệ với quý khách trong vòng 10-15 phút để xác nhận đơn hàng.</p>

                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-hero rounded-pill px-4 py-3 fw-semibold">
                        <i class="fa-solid fa-basket-shopping me-2"></i>Tiếp tục mua hàng
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success rounded-pill px-4 py-3 fw-semibold">
                        <i class="fa-solid fa-house me-2"></i>Quay lại trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
