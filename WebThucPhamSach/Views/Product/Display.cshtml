@model webthucphamsach.Models.Product

@{
    ViewData["Title"] = "Chi Tiết Thực Phẩm: " + Model.Name;
}

<div class="container mt-5 animate-fade-in">
    <!-- Nút quay lại -->
    <div class="mb-4">
        <a asp-action="Index" class="text-success text-decoration-none fw-semibold d-inline-flex align-items-center gap-2">
            <i class="fa-solid fa-arrow-left"></i>
            <span>Quay lại danh sách sản phẩm</span>
        </a>
    </div>

    <!-- Chi tiết sản phẩm kiểu Thẻ Premium -->
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden bg-white mb-5">
        <div class="row g-0">
            <!-- Cột hình ảnh sản phẩm lớn -->
            <div class="col-md-6" style="background-color: #f8faf7;">
                <div class="h-100 w-100 d-flex align-items-center justify-content-center p-4">
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded-4 shadow-sm" style="max-height: 400px; width: 100%; object-fit: cover;" onerror="this.onerror=null;this.src='https://placehold.co/500x400?text=Organic+Food';" />
                </div>
            </div>

            <!-- Cột thông tin chi tiết -->
            <div class="col-md-6">
                <div class="card-body p-5 d-flex flex-column h-100">
                    <!-- Danh mục -->
                    <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2 fw-semibold mb-3 align-self-start">
                        <i class="fa-solid fa-tag me-1"></i> @ViewBag.CategoryName
                    </span>

                    <!-- Tên thực phẩm -->
                    <h2 class="card-title fw-bold text-dark mb-3">@Model.Name</h2>

                    <!-- Giá bán -->
                    <div class="mb-4">
                        <span class="text-muted small d-block mb-1">Giá bán hiện tại:</span>
                        <span class="fs-2 fw-bold text-success">
                            @Model.Price.ToString("N0") <span class="fs-5 fw-normal text-muted">đ / đơn vị</span>
                        </span>
                    </div>

                    <!-- Đường chia cắt nhẹ -->
                    <hr class="text-muted opacity-25 mb-4">

                    <!-- Mô tả sản phẩm -->
                    <div class="mb-4">
                        <h5 class="fw-bold text-dark mb-2"><i class="fa-solid fa-circle-info text-success me-1"></i> Thông Tin Sản Phẩm:</h5>
                        <p class="card-text text-secondary" style="font-size: 0.95rem; line-height: 1.8;">
                            @Model.Description
                        </p>
                    </div>

                    <!-- Cam kết chất lượng trong chi tiết -->
                    <div class="bg-light rounded-3 p-3 mb-4 border border-light-subtle">
                        <div class="d-flex align-items-center gap-2 text-success fw-semibold small">
                            <i class="fa-solid fa-circle-check"></i>
                            <span>Sản phẩm cam kết đạt chuẩn an toàn VietGAP 100% tươi sạch.</span>
                        </div>
                    </div>

                    <!-- Các nút hành động quản lý -->
                    <div class="mt-auto pt-3 d-flex gap-3">
                        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning text-white rounded-3 px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                            <i class="fa-solid fa-pen-to-square"></i>
                            <span>Chỉnh Sửa</span>
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger rounded-3 px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                            <i class="fa-solid fa-trash-can"></i>
                            <span>Xóa Mặt Hàng</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
