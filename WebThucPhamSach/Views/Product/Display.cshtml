@model Product
@{
    ViewData["Title"] = Model.Name + " - Chi tiết sản phẩm";
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index" class="text-success text-decoration-none">
                <i class="bi bi-house-door-fill me-1"></i>Trang chủ
            </a>
        </li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<!-- ==================== CHI TIẾT SẢN PHẨM ==================== -->
<div class="card border-0 shadow-lg rounded-4 overflow-hidden">
    <div class="row g-0">
        <!-- Ảnh sản phẩm -->
        <div class="col-md-5">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="~/images/@Model.ImageUrl"
                     class="img-fluid w-100 h-100"
                     style="object-fit: cover; min-height: 380px;"
                     alt="@Model.Name" />
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center h-100"
                     style="min-height: 380px;">
                    <div class="text-center text-muted">
                        <i class="bi bi-image display-1"></i>
                        <p class="mt-2">Chưa có hình ảnh</p>
                    </div>
                </div>
            }
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-7">
            <div class="card-body p-4 p-md-5">
                <!-- Badge danh mục -->
                <span class="badge bg-success mb-3 px-3 py-2">
                    <i class="bi bi-tag-fill me-1"></i>@ViewBag.CategoryName
                </span>

                <!-- Tên sản phẩm -->
                <h2 class="card-title fw-bold text-dark mb-3">@Model.Name</h2>

                <!-- Giá -->
                <div class="bg-success bg-opacity-10 rounded-3 p-3 mb-4">
                    <h3 class="text-success fw-bold mb-0">
                        <i class="bi bi-tag me-2"></i>@Model.Price.ToString("N0") ₫
                    </h3>
                </div>

                <!-- Mô tả -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <h6 class="fw-bold text-dark mb-2">
                        <i class="bi bi-info-circle-fill text-success me-2"></i>Mô tả sản phẩm
                    </h6>
                    <p class="text-muted lh-lg mb-4">@Model.Description</p>
                }

                <!-- Chứng nhận chất lượng -->
                <div class="row g-2 mb-4">
                    <div class="col-4">
                        <div class="border rounded-3 p-2 text-center">
                            <i class="bi bi-shield-check text-success fs-5"></i>
                            <p class="mb-0 small mt-1">An toàn</p>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="border rounded-3 p-2 text-center">
                            <i class="bi bi-patch-check text-success fs-5"></i>
                            <p class="mb-0 small mt-1">Chứng nhận</p>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="border rounded-3 p-2 text-center">
                            <i class="bi bi-truck text-success fs-5"></i>
                            <p class="mb-0 small mt-1">Giao nhanh</p>
                        </div>
                    </div>
                </div>

                <hr />

                <!-- ============ NÚT HÀNH ĐỘNG theo Role ============ -->
                <div class="d-flex gap-2 flex-wrap">

                    @* Nút dành cho User thường (Member hoặc chưa đăng nhập) *@
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại
                    </a>

                    @if (SignInManager.IsSignedIn(User))
                    {
                        @* Nút Thêm vào giỏ hàng cho User đã đăng nhập *@
                        <button class="btn btn-success btn-lg px-4">
                            <i class="bi bi-cart-plus me-1"></i> Thêm vào giỏ hàng
                        </button>
                    }
                    else
                    {
                        @* Nếu chưa đăng nhập: mời đăng nhập để mua *@
                        <a asp-controller="Account" asp-action="Login"
                           asp-route-returnUrl="@Context.Request.Path"
                           class="btn btn-success btn-lg px-4">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập để mua
                        </a>
                    }

                    @* Nút Quản lý chỉ hiện với Admin *@
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-area="Admin" asp-controller="Product" asp-action="Update"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i> Sửa
                        </a>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Delete"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-danger">
                            <i class="bi bi-trash me-1"></i> Xóa
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
