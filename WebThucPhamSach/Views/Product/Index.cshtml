@model IEnumerable<Product>
@{
    ViewData["Title"] = "Thực phẩm sạch Organic";
    var categories = ViewBag.Categories as IEnumerable<WebThucPhamSach.Models.Category>;
    int? selectedCategoryId = ViewBag.SelectedCategoryId;
    string? selectedCategoryName = ViewBag.SelectedCategoryName;
}

<!-- ==================== BANNER ==================== -->
<div class="text-white rounded-4 p-5 mb-4 shadow-sm"
     style="background: linear-gradient(135deg, #1b4332 0%, #2d6a4f 60%, #52b788 100%);">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold mb-2">
                <i class="bi bi-leaf me-2"></i>
                @(selectedCategoryName != null ? selectedCategoryName : "Thực phẩm sạch - Organic")
            </h2>
            <p class="lead mb-0 opacity-90">
                @(selectedCategoryName != null
                    ? $"Đang xem danh mục: {selectedCategoryName}"
                    : "100% nguồn gốc rõ ràng · Đạt tiêu chuẩn VietGAP · An toàn cho sức khỏe")
            </p>
        </div>
        <div class="col-md-4 text-center d-none d-md-block">
            <i class="bi bi-basket2-fill" style="font-size: 5rem; opacity: 0.3;"></i>
        </div>
    </div>
</div>

<!-- ==================== BỘ LỌC DANH MỤC ==================== -->
<div class="mb-4 d-flex gap-2 flex-wrap align-items-center">
    <span class="text-muted fw-600 me-1"><i class="bi bi-funnel me-1"></i>Lọc:</span>
    <a asp-action="Index" asp-route-categoryId=""
       class="btn btn-sm @(selectedCategoryId == null ? "btn-success" : "btn-outline-success") rounded-pill px-3">
        Tất cả
    </a>
    @if (categories != null)
    {
        @foreach (var cat in categories)
        {
            <a asp-action="Index" asp-route-categoryId="@cat.Id"
               class="btn btn-sm @(selectedCategoryId == cat.Id ? "btn-success" : "btn-outline-success") rounded-pill px-3">
                @cat.Name
            </a>
        }
    }
</div>

<!-- ==================== LƯỚI SẢN PHẨM ==================== -->
@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <h4 class="text-muted mt-3">Không có sản phẩm nào</h4>
        <p class="text-muted">Danh mục này chưa có sản phẩm.</p>
        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
        {
            <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-success">
                <i class="bi bi-plus-lg me-1"></i> Thêm sản phẩm đầu tiên
            </a>
        }
    </div>
}
else
{
    <div class="mb-3 text-muted small">
        Hiển thị <strong>@Model.Count()</strong> sản phẩm
    </div>
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card"
                     style="transition: transform 0.2s, box-shadow 0.2s;">
                    <!-- Hình ảnh sản phẩm -->
                    <div style="height: 200px; overflow: hidden; background: #f8f9fa;">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="~/images/@product.ImageUrl"
                                 class="w-100 h-100"
                                 style="object-fit: cover;"
                                 alt="@product.Name" />
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                            </div>
                        }
                    </div>

                    <!-- Nội dung Card -->
                    <div class="card-body d-flex flex-column p-3">
                        <h5 class="card-title fw-bold text-dark mb-1">@product.Name</h5>

                        @if (!string.IsNullOrEmpty(product.Description))
                        {
                            <p class="card-text text-muted small flex-grow-1 mb-2">
                                @(product.Description.Length > 70
                                    ? product.Description[..70] + "..."
                                    : product.Description)
                            </p>
                        }

                        <div class="d-flex align-items-center justify-content-between mt-auto pt-2 border-top">
                            <span class="text-success fw-bold fs-5">
                                @product.Price.ToString("N0") ₫
                            </span>
                            <a asp-action="Display" asp-route-id="@product.Id"
                               class="btn btn-success btn-sm rounded-pill px-3">
                                <i class="bi bi-eye me-1"></i> Xem
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.12) !important;
    }
</style>
