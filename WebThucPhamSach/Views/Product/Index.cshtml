@model IEnumerable<webthucphamsach.Models.Product>

@{
    ViewData["Title"] = "Quản Lý Thực Phẩm Sạch";
    var categories = ViewBag.Categories as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container mt-4 animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div>
            <span class="text-success fw-bold text-uppercase letter-spacing-1" style="font-size: 0.85rem;">Hệ Thống Quản Trị</span>
            <h1 class="h2 fw-bold text-dark m-0">Quản Lý Kho Thực Phẩm Sạch</h1>
        </div>
        <a asp-action="Add" class="btn btn-hero btn-sm px-4 py-2 d-inline-flex align-items-center gap-2">
            <i class="fa-solid fa-plus-circle"></i>
            <span>Thêm Thực Phẩm Mới</span>
        </a>
    </div>

    <!-- Bảng Danh Sách Sản Phẩm Premium -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="min-width: 800px;">
                <thead class="table-success text-success" style="background-color: var(--primary-light); border-bottom: 2px solid #d0ebd4;">
                    <tr>
                        <th class="py-3 px-4 text-center" style="width: 80px;">Hình ảnh</th>
                        <th class="py-3 px-3">Tên thực phẩm</th>
                        <th class="py-3 px-3">Danh mục</th>
                        <th class="py-3 px-3 text-end" style="width: 150px;">Giá bán</th>
                        <th class="py-3 px-3 text-center" style="width: 250px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var product in Model)
                        {
                            <tr>
                                <!-- Hình ảnh thu nhỏ -->
                                <td class="px-4 text-center">
                                    <div class="rounded-3 overflow-hidden border" style="width: 60px; height: 60px; background-color: #f8f9fa;">
                                        <img src="@product.ImageUrl" alt="@product.Name" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.onerror=null;this.src='https://placehold.co/100x100?text=Food';" />
                                    </div>
                                </td>
                                <!-- Tên & mô tả ngắn -->
                                <td class="px-3">
                                    <h6 class="fw-bold text-dark mb-1">@product.Name</h6>
                                    <p class="text-muted mb-0 small text-truncate" style="max-width: 300px;">@product.Description</p>
                                </td>
                                <!-- Danh mục -->
                                <td class="px-3">
                                    <span class="badge rounded-pill bg-light text-success border border-success-subtle px-3 py-2 fw-semibold">
                                        @(categories.ContainsKey(product.CategoryId) ? categories[product.CategoryId] : "Khác")
                                    </span>
                                </td>
                                <!-- Giá bán -->
                                <td class="px-3 text-end fw-bold text-success fs-5">
                                    @product.Price.ToString("N0") <span class="fs-6 fw-normal text-muted">đ</span>
                                </td>
                                <!-- Các nút điều hướng CRUD -->
                                <td class="px-3 text-center">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-sm btn-light border text-primary rounded-3 px-3 py-2" title="Chi tiết">
                                            <i class="fa-solid fa-eye me-1"></i> Xem
                                        </a>
                                        <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-sm btn-light border text-warning rounded-3 px-3 py-2" title="Sửa">
                                            <i class="fa-solid fa-pen me-1"></i> Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-light border text-danger rounded-3 px-3 py-2" title="Xóa">
                                            <i class="fa-solid fa-trash me-1"></i> Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-5 text-center text-muted">
                                <i class="fa-solid fa-box-open fa-3x mb-3 text-success" style="opacity: 0.3;"></i>
                                <p class="mb-0">Kho hàng hiện tại trống. Hãy thêm thực phẩm mới!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
