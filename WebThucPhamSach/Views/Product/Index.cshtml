@model IEnumerable<Product>

@{
    ViewData["Title"] = "Danh sách Thực phẩm sạch";
}

<!-- ==================== BANNER GIỚI THIỆU ==================== -->
<div class="bg-success bg-gradient text-white rounded-3 p-5 mb-4 shadow">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold mb-3">
                <i class="bi bi-leaf me-2"></i>Thực phẩm sạch - Organic
            </h2>
            <p class="lead mb-0">
                Khám phá bộ sưu tập thực phẩm hữu cơ tươi ngon, an toàn cho sức khỏe.
                100% nguồn gốc rõ ràng, đạt tiêu chuẩn VietGAP.
            </p>
        </div>
        <div class="col-md-4 text-center d-none d-md-block">
            <i class="bi bi-basket2-fill display-1"></i>
        </div>
    </div>
</div>

<!-- ==================== TIÊU ĐỀ VÀ NÚT THÊM MỚI ==================== -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-success fw-bold mb-0">
        <i class="bi bi-grid-3x3-gap-fill me-2"></i>Danh sách sản phẩm
    </h3>
    <!-- Nút thêm sản phẩm mới -->
    <a asp-action="Add" class="btn btn-success btn-lg shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Thêm sản phẩm
    </a>
</div>

<!-- ==================== LƯỚI SẢN PHẨM DẠNG CARD ==================== -->
<!-- Sử dụng Bootstrap Grid: 3 cột trên PC (col-md-4), 1 cột trên Mobile (mặc định col-12) -->
<div class="row">
    @foreach (var product in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <!-- Card hiển thị thông tin sản phẩm -->
            <div class="card h-100 shadow-sm border-0 product-card">
                <!-- Hình ảnh sản phẩm -->
                @if (!string.IsNullOrEmpty(product.ImageUrl))
                {
                    <img src="~/images/@product.ImageUrl"
                         class="card-img-top product-img"
                         alt="@product.Name" />
                }
                else
                {
                    <!-- Placeholder nếu chưa có ảnh -->
                    <div class="card-img-top product-img-placeholder bg-light d-flex align-items-center justify-content-center">
                        <i class="bi bi-image text-muted display-4"></i>
                    </div>
                }

                <!-- Nội dung Card -->
                <div class="card-body d-flex flex-column">
                    <!-- Tên sản phẩm -->
                    <h5 class="card-title fw-bold text-dark">@product.Name</h5>

                    <!-- Giá tiền - Định dạng tiền Việt Nam -->
                    <p class="card-text text-success fw-bold fs-5">
                        @product.Price.ToString("N0") VNĐ
                    </p>

                    <!-- Mô tả ngắn (cắt bớt nếu quá dài) -->
                    @if (!string.IsNullOrEmpty(product.Description))
                    {
                        <p class="card-text text-muted small flex-grow-1">
                            @(product.Description.Length > 80
                                ? product.Description.Substring(0, 80) + "..."
                                : product.Description)
                        </p>
                    }

                    <!-- Các nút hành động -->
                    <div class="mt-auto pt-3">
                        <!-- Nút Xem chi tiết - dẫn đến trang Display -->
                        <a asp-action="Display" asp-route-id="@product.Id"
                           class="btn btn-outline-success w-100 mb-2">
                            <i class="bi bi-eye-fill me-1"></i> Xem chi tiết
                        </a>
                        <!-- Nút Sửa và Xóa trên cùng một hàng -->
                        <div class="d-flex gap-2">
                            <a asp-action="Update" asp-route-id="@product.Id"
                               class="btn btn-outline-primary btn-sm flex-fill">
                                <i class="bi bi-pencil-square me-1"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@product.Id"
                               class="btn btn-outline-danger btn-sm flex-fill">
                                <i class="bi bi-trash3-fill me-1"></i> Xóa
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Thông báo khi không có sản phẩm nào -->
@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <h4 class="text-muted mt-3">Chưa có sản phẩm nào</h4>
        <p class="text-muted">Hãy thêm sản phẩm đầu tiên vào danh sách!</p>
        <a asp-action="Add" class="btn btn-success btn-lg">
            <i class="bi bi-plus-lg me-1"></i> Thêm sản phẩm ngay
        </a>
    </div>
}
