@model webthucphamsach.Models.Product

@{
    ViewData["Title"] = "Chỉnh Sửa Thực Phẩm: " + Model.Name;
}

<div class="container mt-5 animate-fade-in mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-12">
            <!-- Nút quay lại -->
            <div class="mb-4">
                <a asp-action="Index" class="text-success text-decoration-none fw-semibold d-inline-flex align-items-center gap-2">
                    <i class="fa-solid fa-arrow-left"></i>
                    <span>Quay lại danh sách sản phẩm</span>
                </a>
            </div>

            <!-- Form Card Premium -->
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden bg-white">
                <div class="card-header bg-warning text-white py-4 px-4 border-0">
                    <h3 class="card-title m-0 fw-bold d-flex align-items-center gap-2">
                        <i class="fa-solid fa-pen-to-square"></i>
                        <span>Cập Nhật Thông Tin Thực Phẩm</span>
                    </h3>
                    <p class="m-0 text-white-50 small mt-1">Thay đổi các thông tin cần thiết và bấm lưu để cập nhật vào cơ sở dữ liệu kho.</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Update" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        
                        <!-- Lưu ý bắt buộc: Hidden field cho ID sản phẩm -->
                        <input type="hidden" asp-for="Id" />

                        <!-- Nhóm Tên sản phẩm -->
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-dark mb-2"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-success border-end-0"><i class="fa-solid fa-file-signature"></i></span>
                                <input asp-for="Name" class="form-control border-start-0 ps-0" placeholder="Tên sản phẩm thực phẩm sạch..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block fw-semibold"></span>
                        </div>

                        <!-- Hàng gồm Giá bán & Danh mục -->
                        <div class="row mb-4">
                            <!-- Giá bán -->
                            <div class="col-md-6 col-12 mb-4 mb-md-0">
                                <label asp-for="Price" class="form-label fw-bold text-dark mb-2"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-success border-end-0"><i class="fa-solid fa-tag"></i></span>
                                    <input asp-for="Price" class="form-control border-start-0 ps-0" type="number" placeholder="Giá tiền..." />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small mt-1 d-block fw-semibold"></span>
                            </div>
                            <!-- Danh mục -->
                            <div class="col-md-6 col-12">
                                <label asp-for="CategoryId" class="form-label fw-bold text-dark mb-2"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-success border-end-0"><i class="fa-solid fa-folder-tree"></i></span>
                                    <select asp-for="CategoryId" class="form-select border-start-0 ps-0" asp-items="ViewBag.Categories">
                                    </select>
                                </div>
                                <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block fw-semibold"></span>
                            </div>
                        </div>

                        <!-- Nhóm Chọn ảnh đại diện có hiển thị ảnh cũ -->
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark mb-2">Hình ảnh sản phẩm</label>
                            
                            <!-- Hiển thị hình ảnh cũ hiện tại -->
                            <div class="d-flex align-items-center gap-3 mb-3 p-3 bg-light rounded-3 border border-light-subtle">
                                <div class="rounded-3 overflow-hidden border" style="width: 80px; height: 80px; background-color: #ffffff;">
                                    <img src="@Model.ImageUrl" alt="Ảnh hiện tại" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.onerror=null;this.src='https://placehold.co/100x100?text=Food';" />
                                </div>
                                <div>
                                    <span class="text-secondary small d-block fw-bold mb-1">Ảnh hiện tại:</span>
                                    <span class="text-muted small text-break" style="font-size: 0.8rem;">@Model.ImageUrl</span>
                                </div>
                            </div>

                            <!-- Input chọn ảnh mới -->
                            <label class="form-label text-dark small fw-semibold" for="ImageFile">Tải lên hình ảnh thay thế (nếu muốn thay đổi):</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-success border-end-0"><i class="fa-solid fa-image"></i></span>
                                <input type="file" name="ImageFile" id="ImageFile" class="form-control border-start-0 ps-0" accept="image/*" />
                            </div>
                        </div>

                        <!-- Nhóm Mô tả chi tiết -->
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold text-dark mb-2"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả sản phẩm..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-1 d-block fw-semibold"></span>
                        </div>

                        <!-- Nút Lưu & Hủy -->
                        <div class="d-flex gap-3 justify-content-end mt-5">
                            <a asp-action="Index" class="btn btn-light border px-4 py-2 rounded-3 text-secondary fw-semibold">Hủy Bỏ</a>
                            <button type="submit" class="btn btn-warning text-white px-4 py-2 rounded-3 fw-semibold">Cập Nhật Sản Phẩm</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
