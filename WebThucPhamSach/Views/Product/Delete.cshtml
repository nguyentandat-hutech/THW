@model Product

@{
    ViewData["Title"] = "Xóa - " + Model.Name;
}

<!-- ==================== TRANG XÁC NHẬN XÓA SẢN PHẨM ==================== -->
<!-- Breadcrumb điều hướng -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index" class="text-success text-decoration-none">
                <i class="bi bi-house-door-fill me-1"></i>Trang chủ
            </a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Xóa: @Model.Name</li>
    </ol>
</nav>

<!-- Card cảnh báo xác nhận xóa -->
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-danger shadow-lg rounded-3">
            <!-- Header cảnh báo đỏ -->
            <div class="card-header bg-danger text-white text-center py-3">
                <h4 class="mb-0">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Xác nhận xóa sản phẩm
                </h4>
            </div>

            <div class="card-body p-4">
                <!-- Thông báo cảnh báo -->
                <div class="alert alert-warning mb-4">
                    <i class="bi bi-exclamation-circle-fill me-2"></i>
                    <strong>Cảnh báo:</strong> Bạn có chắc chắn muốn xóa sản phẩm này?
                    Hành động này không thể hoàn tác!
                </div>

                <!-- Hiển thị thông tin sản phẩm sắp bị xóa -->
                <div class="row align-items-center">
                    <!-- Ảnh sản phẩm -->
                    <div class="col-md-4 text-center mb-3">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="~/images/@Model.ImageUrl"
                                 class="img-fluid rounded-3 shadow-sm"
                                 alt="@Model.Name"
                                 style="max-height: 200px;" />
                        }
                        else
                        {
                            <div class="bg-light rounded-3 p-4">
                                <i class="bi bi-image display-4 text-muted"></i>
                            </div>
                        }
                    </div>

                    <!-- Thông tin sản phẩm -->
                    <div class="col-md-8">
                        <table class="table table-borderless">
                            <tr>
                                <th class="text-muted" style="width: 130px;">
                                    <i class="bi bi-hash me-1"></i>Mã SP:
                                </th>
                                <td class="fw-bold">@Model.Id</td>
                            </tr>
                            <tr>
                                <th class="text-muted">
                                    <i class="bi bi-tag-fill me-1"></i>Tên SP:
                                </th>
                                <td class="fw-bold text-dark">@Model.Name</td>
                            </tr>
                            <tr>
                                <th class="text-muted">
                                    <i class="bi bi-currency-exchange me-1"></i>Giá:
                                </th>
                                <td class="fw-bold text-success">@Model.Price.ToString("N0") VNĐ</td>
                            </tr>
                            <tr>
                                <th class="text-muted">
                                    <i class="bi bi-folder-fill me-1"></i>Danh mục:
                                </th>
                                <td>@ViewBag.CategoryName</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <hr class="my-4" />

                <!-- Các nút hành động -->
                <div class="d-flex justify-content-center gap-3">
                    <!-- Form xác nhận xóa - POST đến action DeleteConfirmed -->
                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger btn-lg px-5">
                            <i class="bi bi-trash3-fill me-1"></i> Xác nhận xóa
                        </button>
                    </form>

                    <!-- Nút hủy - quay lại danh sách -->
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5">
                        <i class="bi bi-arrow-left me-1"></i> Hủy bỏ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
