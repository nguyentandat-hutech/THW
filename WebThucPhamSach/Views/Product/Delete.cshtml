@model webthucphamsach.Models.Product

@{
    ViewData["Title"] = "Xác Nhận Xóa Thực Phẩm: " + Model.Name;
}

<div class="container mt-5 animate-fade-in mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 col-12">
            
            <!-- Cảnh báo nguy hiểm -->
            <div class="alert alert-danger border-0 shadow-sm rounded-4 p-4 mb-4 d-flex align-items-start gap-3">
                <i class="fa-solid fa-triangle-exclamation fa-2x text-danger mt-1"></i>
                <div>
                    <h4 class="alert-heading fw-bold">Xác Nhận Xóa Thực Phẩm!</h4>
                    <p class="mb-0 small">Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa hoàn toàn mặt hàng này ra khỏi kho dữ liệu quản lý?</p>
                </div>
            </div>

            <!-- Card tóm tắt sản phẩm bị xóa -->
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden bg-white mb-4">
                <div class="p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 overflow-hidden border" style="width: 80px; height: 80px; background-color: #f8f9fa; flex-shrink: 0;">
                            <img src="@Model.ImageUrl" alt="@Model.Name" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.onerror=null;this.src='https://placehold.co/100x100?text=Food';" />
                        </div>
                        <div>
                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 small fw-semibold mb-1">
                                @ViewBag.CategoryName
                            </span>
                            <h5 class="fw-bold text-dark mb-1">@Model.Name</h5>
                            <p class="text-danger fw-bold mb-0">@Model.Price.ToString("N0") đ</p>
                        </div>
                    </div>
                    
                    <hr class="my-3 opacity-25">
                    
                    <div>
                        <span class="text-secondary small fw-bold d-block mb-1">Mô tả sản phẩm:</span>
                        <p class="text-muted small mb-0" style="line-height: 1.6;">@Model.Description</p>
                    </div>
                </div>
            </div>

            <!-- Form nút xác nhận -->
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                
                <div class="d-flex gap-3 justify-content-center">
                    <a asp-action="Index" class="btn btn-light border px-4 py-2 rounded-3 text-secondary fw-semibold">Hủy Bỏ (Quay lại)</a>
                    <button type="submit" class="btn btn-danger px-4 py-2 rounded-3 fw-semibold d-inline-flex align-items-center gap-2">
                        <i class="fa-solid fa-trash-can"></i>
                        <span>Thực Hiện Xóa</span>
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>
