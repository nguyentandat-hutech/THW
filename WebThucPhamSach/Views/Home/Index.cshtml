@model IEnumerable<webthucphamsach.Models.Product>

@{
    ViewData["Title"] = "Trang Chủ - Cửa Hàng Thực Phẩm Sạch";
    var categories = ViewBag.Categories as Dictionary<int, string> ?? new Dictionary<int, string>();
    // Group and count products by category dynamically
    var categoryCounts = Model != null 
        ? Model.GroupBy(p => p.CategoryId).ToDictionary(g => g.Key, g => g.Count()) 
        : new Dictionary<int, int>();
}

<!-- PHẦN CHÀO MỪNG (HERO SECTION) -->
<div class="container mt-4">
    <div class="hero-section animate-fade-in">
        <div class="row align-items-center">
            <!-- Nội dung chữ -->
            <div class="col-lg-6 col-12 mb-4 mb-lg-0">
                <span class="hero-tagline">100% Hữu cơ tự nhiên</span>
                <h1 class="hero-title">Thực phẩm <span>Sạch & Xanh</span><br>Cho gia đình bạn</h1>
                <p class="hero-desc">Chúng tôi mang lại nguồn năng lượng sống dồi dào từ tự nhiên đến trực tiếp bàn ăn của bạn. Các sản phẩm đều đạt chứng nhận chuẩn VietGAP, GlobalGAP tốt cho sức khỏe.</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-hero">Khám phá ngay <i class="fa-solid fa-basket-shopping ms-1"></i></a>
            </div>
            <!-- Hình ảnh minh họa -->
            <div class="col-lg-6 col-12 text-center">
                <img src="https://images.unsplash.com/photo-1542838132-92c53300491e?w=800&auto=format&fit=crop&q=80" alt="Rau quả tươi sạch hữu cơ" class="hero-image rounded shadow-sm img-fluid">
            </div>
        </div>
    </div>
</div>

<!-- BỐ CỤC CHÍNH CỦA TRANG CHỦ (2 CỘT) -->
<main class="container mb-5">
    <div class="row">
        
        <!-- CỘT TRÁI (CHIẾM 75% TRÊN MÁY TÍNH - col-lg-9, 100% trên thiết bị di động) -->
        <div class="col-lg-9 col-md-12 col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="section-title">Thực Phẩm Mới Về Hôm Nay</h2>
                <span class="text-muted d-none d-sm-block">Hiển thị @(Model?.Count() ?? 0) sản phẩm</span>
            </div>
            
            <!-- LƯỚI DANH SÁCH SẢN PHẨM (Grid Product Cards) -->
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                
                @if (Model != null && Model.Any())
                {
                    foreach (var product in Model)
                    {
                        <!-- Thẻ sản phẩm động -->
                        <div class="col">
                            <div class="product-card">
                                <div class="product-img-wrapper">
                                    <span class="product-badge">Organic</span>
                                    <img src="@product.ImageUrl" alt="@product.Name" class="product-img" onerror="this.onerror=null;this.src='https://placehold.co/300x200?text=Food';" />
                                </div>
                                <div class="product-info">
                                    <!-- Danh mục tương ứng -->
                                    <span class="product-cat">
                                        @(categories.ContainsKey(product.CategoryId) ? categories[product.CategoryId] : "Thực phẩm")
                                    </span>
                                    
                                    <!-- Click vào tên sẽ xem chi tiết -->
                                    <a asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="product-name">@product.Name</a>
                                    
                                    <!-- Mô tả sản phẩm -->
                                    <p class="product-desc">@product.Description</p>
                                    
                                    <!-- Chân thẻ sản phẩm chứa Giá & Mua ngay -->
                                    <div class="product-footer">
                                        <span class="product-price">@product.Price.ToString("N0") <small class="fs-6 fw-normal text-muted">đ</small></span>
                                        <a asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="btn btn-buy">Mua Ngay <i class="fa-solid fa-cart-plus"></i></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <!-- Khi không có sản phẩm nào -->
                    <div class="col-12 py-5 text-center text-muted">
                        <i class="fa-solid fa-basket-shopping fa-3x mb-3 text-success" style="opacity: 0.3;"></i>
                        <p class="mb-0">Hiện tại chưa có sản phẩm nào. Vui lòng quay lại sau!</p>
                    </div>
                }
                
            </div>
        </div>
        
        <!-- CỘT PHẢI - SIDEBAR (CHIẾM 25% TRÊN MÁY TÍNH - col-lg-3, xếp chồng trên Mobile) -->
        <aside class="col-lg-3 col-md-12 col-12 mt-5 mt-lg-0">
            
            <!-- Widget 1: Danh mục thực phẩm sạch động -->
            <div class="sidebar-widget">
                <h3 class="widget-title">
                    <i class="fa-solid fa-folder-open"></i>
                    <span>Danh Mục Thực Phẩm</span>
                </h3>
                <ul class="category-list">
                    @if (categories.Any())
                    {
                        foreach (var cat in categories)
                        {
                            // Đặt icon và màu phù hợp
                            string iconClass = "fa-solid fa-seedling";
                            string colorClass = "text-success";
                            if (cat.Key == 1) { iconClass = "fa-solid fa-carrot"; colorClass = "text-success"; }
                            else if (cat.Key == 2) { iconClass = "fa-solid fa-apple-whole"; colorClass = "text-danger"; }
                            else if (cat.Key == 3) { iconClass = "fa-solid fa-cow"; colorClass = "text-warning"; }
                            else if (cat.Key == 4) { iconClass = "fa-solid fa-wheat-awn"; colorClass = "text-info"; }

                            <li class="category-item">
                                <a href="#" class="category-link">
                                    <span><i class="@iconClass me-2 @colorClass"></i>@cat.Value</span>
                                    <span class="category-badge">
                                        @(categoryCounts.ContainsKey(cat.Key) ? categoryCounts[cat.Key] : 0)
                                    </span>
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-muted small">Không tìm thấy danh mục</li>
                    }
                </ul>
            </div>
            
            <!-- Widget 2: Banner Khuyến mãi ấn tượng -->
            <div class="sidebar-widget p-0 border-0 overflow-hidden">
                <div class="promo-card">
                    <div class="promo-percent">Giảm 20%</div>
                    <h4 class="promo-title">Giỏ Rau Xanh Cuối Tuần</h4>
                    <p class="promo-desc">Áp dụng cho mọi đơn hàng rau củ quả tươi được đặt từ ngày Thứ Sáu đến Chủ Nhật tuần này.</p>
                    <button class="btn btn-promo">Lấy Mã Ngay <i class="fa-solid fa-ticket ms-1"></i></button>
                </div>
            </div>
            
            <!-- Widget 3: Cam kết chất lượng / Thông tin bổ sung -->
            <div class="sidebar-widget mt-4">
                <h3 class="widget-title">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>Cam Kết GreenFood</span>
                </h3>
                
                <div class="commitment-item">
                    <div class="commitment-icon">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <div class="commitment-text">
                        <h5>Đạt Chuẩn An Toàn</h5>
                        <p>Tất cả sản phẩm đạt kiểm nghiệm VietGAP và có chứng từ nguồn gốc rõ ràng.</p>
                    </div>
                </div>
                
                <div class="commitment-item">
                    <div class="commitment-icon">
                        <i class="fa-solid fa-seedling"></i>
                    </div>
                    <div class="commitment-text">
                        <h5>100% Không Hóa Chất</h5>
                        <p>Không chất bảo quản, không phân bón hóa học và thuốc trừ sâu độc hại.</p>
                    </div>
                </div>
                
                <div class="commitment-item">
                    <div class="commitment-icon">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                    <div class="commitment-text">
                        <h5>Giao Hàng Siêu Tốc 2h</h5>
                        <p>Đảm bảo rau củ quả vẫn giữ trọn vị tươi nguyên từ vườn đến nhà bạn.</p>
                    </div>
                </div>
            </div>
            
        </aside>
        
    </div>
</main>
