@{
    ViewData["Title"] = "Trang Chủ - Cửa Hàng Thực Phẩm Sạch";
}

<!-- PHẦN CHÀO MỪNG (HERO SECTION) -->
<div class="container mt-4">
    <div class="hero-section animate-fade-in">
        <div class="row align-items-center">
            <!-- Nội dung chữ -->
            <div class="col-lg-6 col-12 mb-4 mb-lg-0">
                <span class="hero-tagline">100% Hữu cơ tự nhiên</span>
                <h1 class="hero-title">Thực phẩm <span>Sạch & Xanh</span><br>Cho gia đình bạn</h1>
                <p class="hero-desc">Chúng tôi mang lại nguồn năng lượng sống dồi dào từ tự nhiên đến trực tiếp bàn ăn của bạn. Các sản phẩm đều đạt chứng nhận chuẩn VietGAP, GlobalGAP tốt cho sức khỏe.</p>
                <a href="#" class="btn btn-hero">Khám Phá Ngay <i class="fa-solid fa-circle-arrow-right ms-1"></i></a>
            </div>
            <!-- Hình ảnh minh họa -->
            <div class="col-lg-6 col-12 text-center">
                <img src="https://images.unsplash.com/photo-1542838132-92c53300491e?w=800&auto=format&fit=crop&q=80" alt="Rau quả tươi sạch hữu cơ" class="hero-image rounded shadow-sm img-fluid">
            </div>
        </div>
    </div>
</div>

<!-- BỐ CỤC CHÍNH CỦA TRANG CHỦ (2 CỘT) -->
<main class="container mb-5">
    <div class="row">
        
        <!-- CỘT TRÁI (CHIẾM 75% TRÊN MÁY TÍNH - col-lg-9, 100% trên thiết bị di động) -->
        <div class="col-lg-9 col-md-12 col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="section-title">Thực Phẩm Mới Về Hôm Nay</h2>
                <span class="text-muted d-none d-sm-block">Hiển thị 6 sản phẩm</span>
            </div>
            
            <!-- LƯỚI DANH SÁCH SẢN PHẨM (Grid Product Cards) -->
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                
                <!-- Sản phẩm 1 -->
                <div class="col">
                    <div class="product-card">
                        <div class="product-img-wrapper">
                            <span class="product-badge">VietGAP</span>
                            <img src="https://images.unsplash.com/photo-1576045057995-568f588f82fb?w=600&auto=format&fit=crop&q=80" alt="Cải bó xôi hữu cơ" class="product-img">
                        </div>
                        <div class="product-info">
                            <span class="product-cat">Rau xanh hữu cơ</span>
                            <a href="#" class="product-name">Rau cải bó xôi hữu cơ Đà Lạt</a>
                            <p class="product-desc">Cải bó xôi tươi giòn, giàu chất sắt và vitamin, trồng theo tiêu chuẩn hữu cơ, không thuốc hóa học.</p>
                            <div class="product-footer">
                                <span class="product-price">35.000 đ <small class="text-muted">/ kg</small></span>
                                <button class="btn btn-buy">Mua Ngay <i class="fa-solid fa-cart-plus"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Sản phẩm 2 -->
                <div class="col">
                    <div class="product-card">
                        <div class="product-img-wrapper">
                            <span class="product-badge sale">-15%</span>
                            <img src="https://images.unsplash.com/photo-1619546813926-a78fa6372cd2?w=600&auto=format&fit=crop&q=80" alt="Táo đỏ nhập khẩu" class="product-img">
                        </div>
                        <div class="product-info">
                            <span class="product-cat">Trái cây nhập khẩu</span>
                            <a href="#" class="product-name">Táo đỏ Fuji hữu cơ cao cấp</a>
                            <p class="product-desc">Táo Fuji giòn ngọt, mọng nước, nhập khẩu chính ngạch từ trang trại đạt chuẩn hữu cơ thế giới.</p>
                            <div class="product-footer">
                                <span class="product-price">89.000 đ <del>105.000 đ</del></span>
                                <button class="btn btn-buy">Mua Ngay <i class="fa-solid fa-cart-plus"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Sản phẩm 3 -->
                <div class="col">
                    <div class="product-card">
                        <div class="product-img-wrapper">
                            <span class="product-badge">100% Sạch</span>
                            <img src="https://images.unsplash.com/photo-1598170845058-32b9d6a5da37?w=600&auto=format&fit=crop&q=80" alt="Cà rốt Đà Lạt" class="product-img">
                        </div>
                        <div class="product-info">
                            <span class="product-cat">Củ quả tự nhiên</span>
                            <a href="#" class="product-name">Cà rốt ngọt Đà Lạt VietGAP</a>
                            <p class="product-desc">Củ cà rốt tươi ngon, ngọt đậm, thích hợp dùng làm nước ép hoặc chế biến món ăn bổ dưỡng mỗi ngày.</p>
                            <div class="product-footer">
                                <span class="product-price">28.000 đ <small class="text-muted">/ kg</small></span>
                                <button class="btn btn-buy">Mua Ngay <i class="fa-solid fa-cart-plus"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Sản phẩm 4 -->
                <div class="col">
                    <div class="product-card">
                        <div class="product-img-wrapper">
                            <span class="product-badge sale">Bán chạy</span>
                            <img src="https://images.unsplash.com/photo-1464965911861-746a04b4bca6?w=600&auto=format&fit=crop&q=80" alt="Dâu tây Đà Lạt" class="product-img">
                        </div>
                        <div class="product-info">
                            <span class="product-cat">Trái cây sạch</span>
                            <a href="#" class="product-name">Dâu tây đỏ New Zealand trồng Đà Lạt</a>
                            <p class="product-desc">Dâu tây căng mọng, vị chua ngọt hài hòa, được thu hoạch trực tiếp tại vườn công nghệ cao vào sáng sớm.</p>
                            <div class="product-footer">
                                <span class="product-price">120.000 đ <small class="text-muted">/ hộp 500g</small></span>
                                <button class="btn btn-buy">Mua Ngay <i class="fa-solid fa-cart-plus"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Sản phẩm 5 -->
                <div class="col">
                    <div class="product-card">
                        <div class="product-img-wrapper">
                            <span class="product-badge">Organic</span>
                            <img src="https://images.unsplash.com/photo-1550583724-b2692b85b150?w=600&auto=format&fit=crop&q=80" alt="Sữa tươi & Trứng" class="product-img">
                        </div>
                        <div class="product-info">
                            <span class="product-cat">Trứng & Sữa sạch</span>
                            <a href="#" class="product-name">Trứng gà ta thảo mộc tự nhiên</a>
                            <p class="product-desc">Trứng từ đàn gà ta thả vườn được nuôi dưỡng bằng thảo mộc tự nhiên, hàm lượng dinh dưỡng cao vượt trội.</p>
                            <div class="product-footer">
                                <span class="product-price">45.000 đ <small class="text-muted">/ vỉ 10 quả</small></span>
                                <button class="btn btn-buy">Mua Ngay <i class="fa-solid fa-cart-plus"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Sản phẩm 6 -->
                <div class="col">
                    <div class="product-card">
                        <div class="product-img-wrapper">
                            <span class="product-badge sale">Mới</span>
                            <img src="https://images.unsplash.com/photo-1587049352846-4a222e784d38?w=600&auto=format&fit=crop&q=80" alt="Mật ong rừng" class="product-img">
                        </div>
                        <div class="product-info">
                            <span class="product-cat">Đặc sản vùng miền</span>
                            <a href="#" class="product-name">Mật ong rừng tràm U Minh nguyên chất</a>
                            <p class="product-desc">Mật ong rừng tự nhiên nguyên chất 100%, mùi thơm đặc trưng, vị ngọt thanh tốt cho hệ tiêu hóa.</p>
                            <div class="product-footer">
                                <span class="product-price">180.000 đ <small class="text-muted">/ chai 350ml</small></span>
                                <button class="btn btn-buy">Mua Ngay <i class="fa-solid fa-cart-plus"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
        
        <!-- CỘT PHẢI - SIDEBAR (CHIẾM 25% TRÊN MÁY TÍNH - col-lg-3, xếp chồng trên Mobile) -->
        <aside class="col-lg-3 col-md-12 col-12 mt-5 mt-lg-0">
            
            <!-- Widget 1: Danh mục thực phẩm sạch -->
            <div class="sidebar-widget">
                <h3 class="widget-title">
                    <i class="fa-solid fa-folder-open"></i>
                    <span>Danh Mục Thực Phẩm</span>
                </h3>
                <ul class="category-list">
                    <li class="category-item">
                        <a href="#" class="category-link">
                            <span><i class="fa-solid fa-carrot me-2 text-success"></i>Rau Xanh Hữu Cơ</span>
                            <span class="category-badge">42</span>
                        </a>
                    </li>
                    <li class="category-item">
                        <a href="#" class="category-link">
                            <span><i class="fa-solid fa-apple-whole me-2 text-danger"></i>Trái Cây Sạch</span>
                            <span class="category-badge">28</span>
                        </a>
                    </li>
                    <li class="category-item">
                        <a href="#" class="category-link">
                            <span><i class="fa-solid fa-cow me-2 text-warning"></i>Trứng & Sữa Tươi</span>
                            <span class="category-badge">15</span>
                        </a>
                    </li>
                    <li class="category-item">
                        <a href="#" class="category-link">
                            <span><i class="fa-solid fa-wheat-awn me-2 text-info"></i>Hạt & Đồ Khô Hữu Cơ</span>
                            <span class="category-badge">20</span>
                        </a>
                    </li>
                </ul>
            </div>
            
            <!-- Widget 2: Banner Khuyến mãi ấn tượng -->
            <div class="sidebar-widget p-0 border-0 overflow-hidden">
                <div class="promo-card">
                    <div class="promo-percent">Giảm 20%</div>
                    <h4 class="promo-title">Giỏ Rau Xanh Cuối Tuần</h4>
                    <p class="promo-desc">Áp dụng cho mọi đơn hàng rau củ quả tươi được đặt từ ngày Thứ Sáu đến Chủ Nhật tuần này.</p>
                    <button class="btn btn-promo">Lấy Mã Ngay <i class="fa-solid fa-ticket ms-1"></i></button>
                </div>
            </div>
            
            <!-- Widget 3: Cam kết chất lượng / Thông tin bổ sung -->
            <div class="sidebar-widget mt-4">
                <h3 class="widget-title">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>Cam Kết GreenFood</span>
                </h3>
                
                <div class="commitment-item">
                    <div class="commitment-icon">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <div class="commitment-text">
                        <h5>Đạt Chuẩn An Toàn</h5>
                        <p>Tất cả sản phẩm đạt kiểm nghiệm VietGAP và có chứng từ nguồn gốc rõ ràng.</p>
                    </div>
                </div>
                
                <div class="commitment-item">
                    <div class="commitment-icon">
                        <i class="fa-solid fa-seedling"></i>
                    </div>
                    <div class="commitment-text">
                        <h5>100% Không Hóa Chemicals</h5>
                        <p>Không chất bảo quản, không phân bón hóa học và thuốc trừ sâu độc hại.</p>
                    </div>
                </div>
                
                <div class="commitment-item">
                    <div class="commitment-icon">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                    <div class="commitment-text">
                        <h5>Giao Hàng Siêu Tốc 2h</h5>
                        <p>Đảm bảo rau củ quả vẫn giữ trọn vị tươi nguyên từ vườn đến nhà bạn.</p>
                    </div>
                </div>
            </div>
            
        </aside>
        
    </div>
</main>
