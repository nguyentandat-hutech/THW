@model WebThucPhamSach.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "_Layout";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-5">
                <!-- Icon thành công -->
                <div class="mb-4">
                    <div class="bg-success bg-opacity-10 d-inline-flex justify-content-center align-items-center rounded-circle" style="width: 100px; height: 100px;">
                        <i class="bi bi-bag-check-fill text-success" style="font-size: 3.5rem;"></i>
                    </div>
                </div>

                <h1 class="fw-bold text-success mb-2">Đặt hàng thành công!</h1>
                <p class="text-secondary mb-4 fs-5">Cảm ơn bạn đã tin tưởng lựa chọn thực phẩm sạch hữu cơ của Organic Food Store.</p>

                <!-- Box thông tin đơn hàng nhanh -->
                <div class="row g-3 justify-content-center mb-5">
                    <div class="col-sm-6 col-md-4">
                        <div class="bg-light p-3 rounded-3 text-start h-100">
                            <span class="text-secondary fs-7 d-block">Mã đơn hàng</span>
                            <span class="fw-bold text-dark fs-5">#@Model.Id</span>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="bg-light p-3 rounded-3 text-start h-100">
                            <span class="text-secondary fs-7 d-block">Tổng thanh toán</span>
                            <span class="fw-bold text-success fs-5">@Model.TotalPrice.ToString("#,##0") đ</span>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="bg-light p-3 rounded-3 text-start h-100">
                            <span class="text-secondary fs-7 d-block">Trạng thái</span>
                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-semibold mt-1">@Model.Status</span>
                        </div>
                    </div>
                </div>

                <!-- Chi tiết người nhận -->
                <div class="text-start bg-light p-4 rounded-4 mb-4 border border-light">
                    <h5 class="fw-bold text-dark mb-3"><i class="bi bi-truck text-success me-2"></i>Thông tin vận chuyển</h5>
                    <div class="row g-2">
                        <div class="col-sm-3 text-secondary fw-semibold">Số điện thoại:</div>
                        <div class="col-sm-9 text-dark fw-bold">@Model.PhoneNumber</div>
                        
                        <div class="col-sm-3 text-secondary fw-semibold">Địa chỉ giao:</div>
                        <div class="col-sm-9 text-dark">@Model.ShippingAddress</div>
                        
                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <div class="col-sm-3 text-secondary fw-semibold">Ghi chú:</div>
                            <div class="col-sm-9 text-muted italic">"@Model.Notes"</div>
                        }
                    </div>
                </div>

                <!-- Tóm tắt sản phẩm -->
                <div class="text-start mb-5">
                    <h5 class="fw-bold text-dark mb-3"><i class="bi bi-list-check text-success me-2"></i>Sản phẩm đã mua</h5>
                    <div class="list-group rounded-3 shadow-none border border-light">
                        @foreach (var detail in Model.OrderDetails)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center py-3 border-light bg-white">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-2 overflow-hidden bg-light flex-shrink-0" style="width: 40px; height: 40px;">
                                        <img src="/images/@(string.IsNullOrEmpty(detail.Product.ImageUrl) ? "no-image.jpg" : detail.Product.ImageUrl)" 
                                             class="w-100 h-100 object-fit-cover" 
                                             onerror="this.src='/images/no-image.jpg';" />
                                    </div>
                                    <span class="fw-semibold text-dark ms-3">@detail.Product.Name <span class="text-secondary fw-normal fs-7">x @detail.Quantity</span></span>
                                </div>
                                <span class="fw-bold text-success">@((detail.Price * detail.Quantity).ToString("#,##0")) đ</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Nút điều hướng -->
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-success btn-lg px-4 rounded-pill shadow-sm">
                        <i class="bi bi-shop me-2"></i>Tiếp tục mua sắm
                    </a>
                    <a asp-controller="Order" asp-action="Index" class="btn btn-outline-success btn-lg px-4 rounded-pill">
                        <i class="bi bi-receipt me-2"></i>Đơn hàng của tôi
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .fs-7 {
            font-size: 0.85rem;
        }
        .italic {
            font-style: italic;
        }
        .object-fit-cover {
            object-fit: cover;
        }
    </style>
}
