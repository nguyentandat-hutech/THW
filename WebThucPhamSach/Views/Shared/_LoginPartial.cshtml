@using Microsoft.AspNetCore.Identity
@using webthucphamsach.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <!-- Người dùng đã đăng nhập: Hiển thị lời chào và nút đăng xuất -->
    <div class="d-flex align-items-center gap-2">
        <!-- Lời chào người dùng -->
        <div class="user-greeting d-flex align-items-center gap-2">
            <div class="user-avatar">
                <i class="fa-solid fa-circle-user"></i>
            </div>
            <div class="user-info">
                <span class="user-name">@UserManager.GetUserName(User)</span>
            </div>
        </div>

        <!-- Nút Đăng xuất -->
        <form id="logoutForm" asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
            <button type="submit" class="btn-logout" id="logout-btn" title="Đăng xuất">
                <i class="fa-solid fa-right-from-bracket me-1"></i>
                <span class="d-none d-lg-inline">Đăng xuất</span>
            </button>
        </form>
    </div>
}
else
{
    <!-- Người dùng chưa đăng nhập: Hiển thị liên kết Đăng ký và Đăng nhập -->
    <div class="d-flex align-items-center gap-2">
        <a class="btn-register-nav" id="register-nav-link"
           asp-area="Identity" asp-page="/Account/Register">
            <i class="fa-solid fa-user-plus me-1"></i>
            <span class="d-none d-sm-inline">Đăng ký</span>
        </a>
        <a class="btn-login-nav" id="login-nav-link"
           asp-area="Identity" asp-page="/Account/Login">
            <i class="fa-solid fa-right-to-bracket me-1"></i>
            <span class="d-none d-sm-inline">Đăng nhập</span>
        </a>
    </div>
}
