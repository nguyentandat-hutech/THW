<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GreenFood Organic Store</title>
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- FontAwesome Icons CDN (để lấy icon hiện đại) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <!-- Style CSS Tùy Chỉnh -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/webthucphamsach.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- THÀNH MENU ĐIỀU HƯỚNG (NAVBAR) -->
    <nav class="navbar navbar-expand-lg navbar-custom sticky-top">
        <div class="container">
            <!-- Logo Thương hiệu -->
            <a class="navbar-brand navbar-brand-custom" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-leaf"></i>
                <span>GreenFood</span>
            </a>
            
            <!-- Nút Toggle trên thiết bị di động -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <!-- Menu nội dung chính -->
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom active" asp-area="" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-house me-1"></i> Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" asp-area="" asp-controller="Product" asp-action="Index"><i class="fa-solid fa-basket-shopping me-1"></i> Sản phẩm</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="Privacy"><i class="fa-solid fa-envelope me-1"></i> Liên hệ</a>
                    </li>
                </ul>
                
                <!-- Thanh tìm kiếm hiện đại -->
                <form class="d-flex me-3" role="search">
                    <div class="input-group">
                        <input class="form-control search-box" type="search" placeholder="Tìm thực phẩm sạch..." aria-label="Search">
                        <button class="btn btn-search" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
                    </div>
                </form>
                
                <!-- Nút Giỏ hàng (Cart Button) với Badge -->
                <button class="cart-icon-btn" title="Giỏ hàng của bạn">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span class="cart-badge">3</span>
                </button>
            </div>
        </div>
    </nav>

    <!-- NỘI DUNG CHÍNH CỦA TỪNG TRANG -->
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <!-- CHÂN TRANG (FOOTER - CHIA 3 CỘT TRÊN MÁY TÍNH, XẾP CHỒNG TRÊN DI ĐỘNG) -->
    <footer class="footer-custom">
        <div class="container">
            <div class="row g-4">
                
                <!-- Cột 1: Thông tin cửa hàng GreenFood -->
                <div class="col-lg-4 col-md-12 col-12">
                    <a class="footer-brand" href="#">
                        <i class="fa-solid fa-leaf"></i>
                        <span>GreenFood</span>
                    </a>
                    <p class="footer-desc">GreenFood là hệ thống phân phối thực phẩm hữu cơ, rau củ quả sạch chuẩn chất lượng VietGAP lớn nhất toàn quốc. Sứ mệnh của chúng tôi là bảo vệ sức khỏe người Việt qua từng bữa ăn sạch lành.</p>
                    <div class="footer-socials">
                        <a href="#" class="social-btn"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#" class="social-btn"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" class="social-btn"><i class="fa-brands fa-youtube"></i></a>
                        <a href="#" class="social-btn"><i class="fa-brands fa-tiktok"></i></a>
                    </div>
                </div>
                
                <!-- Cột 2: Chính sách mua hàng -->
                <div class="col-lg-4 col-md-6 col-12">
                    <h4 class="footer-title">Chính Sách & Liên Kết</h4>
                    <ul class="footer-links">
                        <li class="footer-link-item">
                            <a href="#" class="footer-link"><i class="fa-solid fa-angle-right me-2"></i>Chính sách đổi trả trong 24h</a>
                        </li>
                        <li class="footer-link-item">
                            <a href="#" class="footer-link"><i class="fa-solid fa-angle-right me-2"></i>Chính sách vận chuyển & giao hàng</a>
                        </li>
                        <li class="footer-link-item">
                            <a href="#" class="footer-link"><i class="fa-solid fa-angle-right me-2"></i>Hướng dẫn mua hàng online</a>
                        </li>
                        <li class="footer-link-item">
                            <a href="#" class="footer-link"><i class="fa-solid fa-angle-right me-2"></i>Cam kết chất lượng thực phẩm</a>
                        </li>
                    </ul>
                </div>
                
                <!-- Cột 3: Liên hệ hỗ trợ -->
                <div class="col-lg-4 col-md-6 col-12">
                    <h4 class="footer-title">Thông Tin Liên Hệ</h4>
                    <div class="footer-contact-item">
                        <i class="fa-solid fa-location-dot"></i>
                        <p>276 Điện Biên Phủ, Phường 17, Quận Bình Thạnh, TP. Hồ Chí Minh (HUTECH Campus)</p>
                    </div>
                    <div class="footer-contact-item">
                        <i class="fa-solid fa-phone"></i>
                        <p>1900 123 456 - 028 3840 578</p>
                    </div>
                    <div class="footer-contact-item">
                        <i class="fa-solid fa-envelope"></i>
                        <p>support@greenfood.vn - info@greenfood.vn</p>
                    </div>
                    <div class="footer-contact-item">
                        <i class="fa-solid fa-clock"></i>
                        <p>Giờ làm việc: 07:00 - 21:00 (Hằng ngày)</p>
                    </div>
                </div>
                
            </div>
            
            <!-- Phần Bản quyền ở đáy Footer -->
            <div class="footer-bottom">
                <p class="m-0">&copy; 2026 GreenFood Organic Store. Tất cả quyền được bảo lưu. Thiết kế và phát triển bởi Đồ án Lập trình Web HUTECH.</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
