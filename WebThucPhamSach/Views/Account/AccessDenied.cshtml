@{
    ViewData["Title"] = "Không có quyền truy cập";
}

<div class="text-center py-5">
    <i class="bi bi-shield-x text-danger" style="font-size:5rem;"></i>
    <h2 class="fw-bold mt-3">Từ chối truy cập</h2>
    <p class="text-muted">Bạn không có quyền truy cập vào trang này.</p>
    <a asp-controller="Product" asp-action="Index" class="btn btn-success">
        <i class="bi bi-house me-1"></i>Về trang chủ
    </a>
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary ms-2">
        <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
    </a>
</div>
