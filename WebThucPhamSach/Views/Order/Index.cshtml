@model IEnumerable<WebThucPhamSach.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "_Layout";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index" class="text-success text-decoration-none">Cửa hàng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Lịch sử đơn hàng</li>
        </ol>
    </nav>

    <h2 class="fw-bold mb-4 text-success">
        <i class="bi bi-receipt me-2"></i>Đơn hàng của tôi
    </h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded-4 bg-white border border-light">
            <div class="mb-4">
                <i class="bi bi-journal-x text-muted" style="font-size: 5rem;"></i>
            </div>
            <h4 class="fw-bold text-secondary">Bạn chưa đặt đơn hàng nào</h4>
            <p class="text-muted mb-4">Hãy mua sắm các thực phẩm hữu cơ bổ dưỡng ngay để bảo vệ sức khỏe gia đình!</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-success btn-lg px-4 rounded-pill shadow-sm">
                <i class="bi bi-shop me-2"></i>Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover table-align-middle mb-0">
                    <thead class="bg-success bg-opacity-10 text-success">
                        <tr>
                            <th scope="col" class="py-3 ps-4" style="width: 120px;">Mã đơn</th>
                            <th scope="col" class="py-3">Ngày đặt</th>
                            <th scope="col" class="py-3">Số điện thoại</th>
                            <th scope="col" class="py-3">Địa chỉ nhận hàng</th>
                            <th scope="col" class="py-3 text-end" style="width: 150px;">Tổng tiền</th>
                            <th scope="col" class="py-3 text-center" style="width: 150px;">Trạng thái</th>
                            <th scope="col" class="py-3 text-center" style="width: 120px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3 fw-bold text-dark">
                                    #@order.Id
                                </td>
                                <td class="py-3 text-secondary">
                                    @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="py-3 fw-semibold">
                                    @order.PhoneNumber
                                </td>
                                <td class="py-3 text-truncate" style="max-width: 250px;" title="@order.ShippingAddress">
                                    @order.ShippingAddress
                                </td>
                                <td class="py-3 text-end fw-bold text-success">
                                    @order.TotalPrice.ToString("#,##0") <span class="fs-7 text-success">đ</span>
                                </td>
                                <td class="py-3 text-center">
                                    @{
                                        string badgeClass = order.Status switch
                                        {
                                            "Chờ duyệt" => "bg-warning text-dark",
                                            "Đã duyệt" => "bg-info text-white",
                                            "Đang giao" => "bg-primary text-white",
                                            "Đã giao" => "bg-success text-white",
                                            "Đã hủy" => "bg-danger text-white",
                                            _ => "bg-secondary text-white"
                                        };
                                    }
                                    <span class="badge @badgeClass px-3 py-2 rounded-pill fw-semibold fs-7">
                                        @order.Status
                                    </span>
                                </td>
                                <td class="py-3 text-center">
                                    <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" 
                                       class="btn btn-outline-success btn-sm rounded-pill px-3 fw-semibold">
                                        <i class="bi bi-eye me-1"></i>Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Styles {
    <style>
        .table-align-middle td {
            vertical-align: middle;
        }
        .fs-7 {
            font-size: 0.8rem;
        }
    </style>
}
