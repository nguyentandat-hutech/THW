@model WebThucPhamSach.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
    Layout = "_Layout";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index" class="text-success text-decoration-none">Cửa hàng</a></li>
            <li class="breadcrumb-item"><a asp-controller="Order" asp-action="Index" class="text-success text-decoration-none">Đơn hàng của tôi</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết #@Model.Id</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center mb-4">
        <a asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle me-3" style="width: 35px; height: 35px; display: inline-flex; align-items: center; justify-content: center;">
            <i class="bi bi-arrow-left fs-5"></i>
        </a>
        <h2 class="fw-bold text-success mb-0">Đơn hàng #@Model.Id</h2>
        <span class="ms-3 text-muted">Đặt ngày @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
    </div>

    <div class="row g-4">
        <!-- Cột thông tin chi tiết hóa đơn -->
        <div class="col-lg-8">
            <!-- Bảng sản phẩm -->
            <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden mb-4">
                <div class="card-header bg-success bg-opacity-10 text-success py-3 px-4">
                    <h5 class="fw-bold mb-0"><i class="bi bi-list-check me-2"></i>Danh sách thực phẩm đã chọn</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-align-middle mb-0">
                        <thead>
                            <tr class="bg-light text-secondary">
                                <th scope="col" class="py-2 ps-4">Sản phẩm</th>
                                <th scope="col" class="py-2 text-end" style="width: 120px;">Giá tại thời điểm mua</th>
                                <th scope="col" class="py-2 text-center" style="width: 100px;">Số lượng</th>
                                <th scope="col" class="py-2 text-end" style="width: 120px;">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in Model.OrderDetails)
                            {
                                var itemTotal = detail.Price * detail.Quantity;
                                <tr class="border-bottom border-light">
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-3 overflow-hidden bg-light border border-light flex-shrink-0" style="width: 50px; height: 50px;">
                                                <img src="~/images/@(string.IsNullOrEmpty(detail.Product.ImageUrl) ? "no-image.jpg" : detail.Product.ImageUrl)" 
                                                     class="w-100 h-100 object-fit-cover" 
                                                     alt="@detail.Product.Name" 
                                                     onerror="this.src='/images/no-image.jpg';" />
                                            </div>
                                            <div class="ms-3">
                                                <span class="fw-bold text-dark d-block">
                                                    @detail.Product.Name
                                                </span>
                                                <span class="badge bg-light text-secondary border border-light fs-8">Nông sản sạch</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end py-3 fw-semibold text-secondary">
                                        @detail.Price.ToString("#,##0") đ
                                    </td>
                                    <td class="text-center py-3 fw-bold">
                                        @detail.Quantity
                                    </td>
                                    <td class="text-end py-3 fw-bold text-success">
                                        @itemTotal.ToString("#,##0") đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Nút hành động phụ -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a asp-controller="Order" asp-action="Index" class="btn btn-outline-success rounded-pill px-4">
                    <i class="bi bi-arrow-left me-2"></i>Trở lại lịch sử mua hàng
                </a>
            </div>
        </div>

        <!-- Cột tóm tắt và địa chỉ giao hàng -->
        <div class="col-lg-4">
            <!-- Trạng thái đơn hàng -->
            <div class="card border-0 shadow-sm rounded-4 bg-white p-4 mb-4">
                <h5 class="fw-bold text-dark mb-3 border-bottom border-light pb-2">Trạng thái đơn hàng</h5>
                <div class="d-flex align-items-center">
                    @{
                        string badgeClass = Model.Status switch
                        {
                            "Chờ duyệt" => "bg-warning text-dark",
                            "Đã duyệt" => "bg-info text-white",
                            "Đang giao" => "bg-primary text-white",
                            "Đã giao" => "bg-success text-white",
                            "Đã hủy" => "bg-danger text-white",
                            _ => "bg-secondary text-white"
                        };
                    }
                    <span class="badge @badgeClass px-4 py-2-5 rounded-pill fw-bold fs-6 w-100 text-center shadow-none">
                        @Model.Status
                    </span>
                </div>
                <div class="mt-3 bg-light p-2-5 rounded-3">
                    <small class="text-muted d-block text-center">
                        <i class="bi bi-info-circle me-1"></i>
                        @if (Model.Status == "Chờ duyệt")
                        {
                            <span>Đơn hàng đang chờ nhân viên của chúng tôi kiểm tra và xác nhận.</span>
                        }
                        else if (Model.Status == "Đã duyệt")
                        {
                            <span>Đơn hàng đã được xác nhận và đang đóng gói.</span>
                        }
                        else if (Model.Status == "Đang giao")
                        {
                            <span>Hàng đang được vận chuyển tới địa chỉ của bạn.</span>
                        }
                        else if (Model.Status == "Đã giao")
                        {
                            <span>Đơn hàng đã được hoàn thành. Cảm ơn bạn!</span>
                        }
                        else if (Model.Status == "Đã hủy")
                        {
                            <span>Đơn hàng này đã bị hủy.</span>
                        }
                    </small>
                </div>
            </div>

            <!-- Thông tin giao hàng -->
            <div class="card border-0 shadow-sm rounded-4 bg-white p-4 mb-4">
                <h5 class="fw-bold text-dark mb-3 border-bottom border-light pb-2"><i class="bi bi-truck text-success me-2"></i>Địa chỉ nhận hàng</h5>
                <div class="mb-3">
                    <span class="text-secondary fs-7 d-block">Khách hàng nhận</span>
                    <span class="fw-bold text-dark">@Model.ApplicationUser?.FullName</span>
                </div>
                <div class="mb-3">
                    <span class="text-secondary fs-7 d-block">Số điện thoại liên hệ</span>
                    <span class="fw-bold text-dark">@Model.PhoneNumber</span>
                </div>
                <div class="mb-3">
                    <span class="text-secondary fs-7 d-block">Địa chỉ nhận hàng</span>
                    <span class="text-dark">@Model.ShippingAddress</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="mb-0 bg-light p-2 rounded-3">
                        <span class="text-secondary fs-7 d-block">Ghi chú giao hàng</span>
                        <span class="text-muted italic fs-7">"@Model.Notes"</span>
                    </div>
                }
            </div>

            <!-- Tổng kết tiền mặt -->
            <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
                <h5 class="fw-bold text-dark mb-3 border-bottom border-light pb-2">Hóa đơn thanh toán</h5>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary">Tạm tính</span>
                    <span class="fw-semibold">@Model.TotalPrice.ToString("#,##0") đ</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-secondary">Phí vận chuyển</span>
                    <span class="text-success fw-semibold">Miễn phí</span>
                </div>
                <hr class="my-2 border-light">
                <div class="d-flex justify-content-between align-items-center mb-0 mt-2">
                    <span class="fw-bold text-dark">Thành tiền</span>
                    <span class="fw-extrabold text-success fs-4">@Model.TotalPrice.ToString("#,##0") đ</span>
                </div>
                <span class="badge bg-light text-secondary border border-light w-100 py-2 rounded-3 mt-3 fw-normal fs-7">
                    <i class="bi bi-cash-stack me-2 text-success"></i>Thanh toán khi nhận hàng (COD)
                </span>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table-align-middle td {
            vertical-align: middle;
        }
        .py-2-5 {
            padding-top: 0.65rem;
            padding-bottom: 0.65rem;
        }
        .p-2-5 {
            padding: 0.65rem;
        }
        .object-fit-cover {
            object-fit: cover;
        }
        .italic {
            font-style: italic;
        }
        .fs-7 {
            font-size: 0.85rem;
        }
        .fs-8 {
            font-size: 0.75rem;
        }
        .fw-extrabold {
            font-weight: 800;
        }
    </style>
}
