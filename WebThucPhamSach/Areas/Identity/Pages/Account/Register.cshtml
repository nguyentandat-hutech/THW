@page
@model webthucphamsach.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GreenFood Organic Store</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: linear-gradient(135deg, #0a3d0a 0%, #1a6b1a 40%, #2d8c2d 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 15px;
        }

        .auth-card {
            background: rgba(255, 255, 255, 0.97);
            border-radius: 20px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.35);
            overflow: hidden;
            width: 100%;
            max-width: 520px;
        }

        .auth-header {
            background: linear-gradient(135deg, #1b5e20, #2e7d32, #388e3c);
            padding: 35px 30px;
            text-align: center;
            color: white;
        }

        .auth-header .brand-icon {
            width: 65px;
            height: 65px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 28px;
            backdrop-filter: blur(10px);
            border: 2px solid rgba(255,255,255,0.3);
        }

        .auth-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.3px;
        }

        .auth-header p {
            font-size: 0.9rem;
            opacity: 0.85;
            margin: 8px 0 0;
        }

        .auth-body {
            padding: 35px 40px;
        }

        .form-label {
            font-weight: 600;
            color: #2e7d32;
            font-size: 0.88rem;
            margin-bottom: 6px;
        }

        .form-control, .form-select {
            border: 1.5px solid #c8e6c9;
            border-radius: 10px;
            padding: 11px 15px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            background: #f9fbe7;
        }

        .form-control:focus, .form-select:focus {
            border-color: #2e7d32;
            box-shadow: 0 0 0 3px rgba(46,125,50,0.15);
            background: #fff;
            outline: none;
        }

        .input-group-text {
            background: #e8f5e9;
            border: 1.5px solid #c8e6c9;
            border-right: none;
            border-radius: 10px 0 0 10px;
            color: #2e7d32;
        }

        .input-group .form-control {
            border-left: none;
            border-radius: 0 10px 10px 0;
        }

        .btn-register {
            background: linear-gradient(135deg, #2e7d32, #43a047);
            border: none;
            border-radius: 12px;
            color: white;
            font-weight: 700;
            font-size: 1rem;
            padding: 13px;
            width: 100%;
            transition: all 0.3s ease;
            letter-spacing: 0.5px;
            box-shadow: 0 4px 15px rgba(46,125,50,0.35);
        }

        .btn-register:hover {
            background: linear-gradient(135deg, #1b5e20, #2e7d32);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(46,125,50,0.45);
            color: white;
        }

        .btn-register:active {
            transform: translateY(0);
        }

        .text-danger {
            font-size: 0.8rem;
            margin-top: 4px;
        }

        .login-link {
            text-align: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e8f5e9;
            font-size: 0.9rem;
            color: #666;
        }

        .login-link a {
            color: #2e7d32;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.2s;
        }

        .login-link a:hover {
            color: #1b5e20;
            text-decoration: underline;
        }

        .validation-summary-errors {
            background: #ffebee;
            border: 1px solid #ffcdd2;
            border-radius: 10px;
            padding: 12px 16px;
            color: #c62828;
            font-size: 0.88rem;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }

        .role-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            background: #e8f5e9;
            color: #2e7d32;
            border: 1px solid #c8e6c9;
            margin-left: 6px;
        }

        .back-home {
            text-align: center;
            margin-top: 15px;
        }

        .back-home a {
            color: #2e7d32;
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 500;
            transition: color 0.2s;
        }

        .back-home a:hover {
            color: #1b5e20;
        }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-card">
            <!-- Header Card -->
            <div class="auth-header">
                <div class="brand-icon">
                    <i class="fa-solid fa-leaf"></i>
                </div>
                <h1>GreenFood</h1>
                <p>Tạo tài khoản để mua thực phẩm sạch hữu cơ</p>
            </div>

            <!-- Body Form -->
            <div class="auth-body">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors mb-4" role="alert"></div>

                    <!-- Họ và Tên -->
                    <div class="mb-3">
                        <label asp-for="Input.FullName" class="form-label">
                            <i class="fa-solid fa-user me-1"></i>@Html.DisplayNameFor(m => m.Input.FullName)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-id-card"></i></span>
                            <input asp-for="Input.FullName"
                                   class="form-control"
                                   autocomplete="name"
                                   placeholder="Nhập họ và tên đầy đủ của bạn"
                                   id="Input_FullName" />
                        </div>
                        <span asp-validation-for="Input.FullName" class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">
                            <i class="fa-solid fa-envelope me-1"></i>@Html.DisplayNameFor(m => m.Input.Email)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-at"></i></span>
                            <input asp-for="Input.Email"
                                   class="form-control"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="example@email.com"
                                   id="Input_Email" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- Mật khẩu -->
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">
                            <i class="fa-solid fa-lock me-1"></i>@Html.DisplayNameFor(m => m.Input.Password)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-key"></i></span>
                            <input asp-for="Input.Password"
                                   class="form-control"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Tối thiểu 6 ký tự"
                                   id="Input_Password" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <!-- Xác nhận mật khẩu -->
                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label">
                            <i class="fa-solid fa-lock me-1"></i>@Html.DisplayNameFor(m => m.Input.ConfirmPassword)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-shield-check"></i></span>
                            <input asp-for="Input.ConfirmPassword"
                                   class="form-control"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Nhập lại mật khẩu"
                                   id="Input_ConfirmPassword" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <!-- Dropdown chọn Vai trò -->
                    <div class="mb-4">
                        <label asp-for="Input.Role" class="form-label">
                            <i class="fa-solid fa-user-shield me-1"></i>@Html.DisplayNameFor(m => m.Input.Role)
                            <span class="role-badge">Phân quyền</span>
                        </label>
                        <select asp-for="Input.Role"
                                asp-items="@Model.RoleList"
                                class="form-select"
                                id="Input_Role">
                            <option value="">-- Chọn vai trò (mặc định: Khách hàng) --</option>
                        </select>
                        <span asp-validation-for="Input.Role" class="text-danger"></span>
                        <div class="form-text text-muted mt-1">
                            <i class="fa-solid fa-circle-info me-1"></i>
                            Nếu không chọn, hệ thống sẽ tự động gán vai trò <strong>Khách hàng</strong>.
                        </div>
                    </div>

                    <!-- Nút Đăng ký -->
                    <button type="submit" class="btn btn-register" id="registerSubmit">
                        <i class="fa-solid fa-user-plus me-2"></i>Tạo Tài Khoản Ngay
                    </button>
                </form>

                <!-- Link đăng nhập -->
                <div class="login-link">
                    Đã có tài khoản?
                    <a id="login-link" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">
                        Đăng nhập tại đây
                    </a>
                </div>

                <!-- Link về trang chủ -->
                <div class="back-home">
                    <a asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-arrow-left me-1"></i>Quay về Trang chủ GreenFood
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
