@model WebThucPhamSach.Models.Category
@{
    ViewData["Title"] = "Thêm danh mục";
}

<div class="d-flex align-items-center mb-4">
    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0"><i class="bi bi-plus-circle text-warning me-2"></i>Thêm danh mục mới</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="admin-card p-4">
            <form asp-area="Admin" asp-controller="Category" asp-action="Add" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label asp-for="Name" class="form-label fw-600 fs-6"></label>
                    <input asp-for="Name" class="form-control form-control-lg" placeholder="Ví dụ: Rau củ hữu cơ" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="bi bi-check-circle me-1"></i> Lưu danh mục
                    </button>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index"
                       class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
