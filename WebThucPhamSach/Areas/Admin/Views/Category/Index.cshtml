@model IEnumerable<webthucphamsach.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục | Admin";
    var productCounts = ViewBag.ProductCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="fw-800 mb-1" style="font-size:1.5rem; color:#1a1a2e;">Quản lý Danh mục</h1>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Phân loại sản phẩm thực phẩm sạch GreenFood</p>
    </div>
    <a asp-area="Admin" asp-controller="Category" asp-action="Add" class="btn-add-new" id="btn-add-category">
        <i class="fa-solid fa-folder-plus me-2"></i>Thêm danh mục mới
    </a>
</div>

<!-- Grid danh mục -->
<div class="row g-3 mb-4">
    @foreach (var cat in Model)
    {
        int count = productCounts.ContainsKey(cat.Id) ? productCounts[cat.Id] : 0;
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="category-card">
                <div class="category-icon-wrap">
                    <i class="fa-solid fa-leaf"></i>
                </div>
                <div class="category-card-body">
                    <h3 class="category-name">@cat.Name</h3>
                    <span class="category-product-count">
                        <i class="fa-solid fa-box-archive me-1"></i>@count sản phẩm
                    </span>
                </div>
                <div class="category-card-actions">
                    <a asp-area="Admin" asp-controller="Category" asp-action="Update" asp-route-id="@cat.Id"
                       class="cat-btn cat-btn-edit" title="Chỉnh sửa">
                        <i class="fa-solid fa-pen"></i>
                    </a>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Delete" asp-route-id="@cat.Id"
                       class="cat-btn cat-btn-delete" title="Xóa">
                        <i class="fa-solid fa-trash"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<!-- Bảng chi tiết -->
<div class="admin-card">
    <div class="admin-card-header">
        <i class="fa-solid fa-table me-2"></i>Chi tiết tất cả danh mục
    </div>
    <div class="table-responsive">
        <table class="table mb-0" id="categoryTable">
            <thead>
                <tr style="background:linear-gradient(135deg,#1a1a2e,#16213e); color:white;">
                    <th class="px-4 py-3" style="border:none; font-size:0.8rem; font-weight:700; letter-spacing:0.5px;">#</th>
                    <th class="px-3 py-3" style="border:none; font-size:0.8rem; font-weight:700; letter-spacing:0.5px;">Tên danh mục</th>
                    <th class="px-3 py-3" style="border:none; font-size:0.8rem; font-weight:700; letter-spacing:0.5px;">Số sản phẩm</th>
                    <th class="px-3 py-3 text-center" style="border:none; font-size:0.8rem; font-weight:700; letter-spacing:0.5px; width:140px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{ int stt = 1; }
                @foreach (var cat in Model)
                {
                    int count = productCounts.ContainsKey(cat.Id) ? productCounts[cat.Id] : 0;
                    <tr style="border-bottom:1px solid #f0f2f5; transition:background 0.15s;"
                        onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
                        <td class="px-4 py-3" style="border:none; color:#aaa; font-weight:700;">@stt</td>
                        <td class="px-3 py-3" style="border:none;">
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:36px;height:36px;background:#e8f5e9;border-radius:10px;display:flex;align-items:center;justify-content:center;color:#2e7d32;font-size:0.9rem;">
                                    <i class="fa-solid fa-leaf"></i>
                                </div>
                                <span style="font-weight:700; color:#1a1a2e; font-size:0.92rem;">@cat.Name</span>
                            </div>
                        </td>
                        <td class="px-3 py-3" style="border:none;">
                            <span style="display:inline-block;padding:4px 14px;background:@(count > 0 ? "#e8f5e9" : "#f5f5f5");color:@(count > 0 ? "#2e7d32" : "#999");border-radius:20px;font-size:0.78rem;font-weight:700;border:1px solid @(count > 0 ? "#c8e6c9" : "#e0e0e0");">
                                @count sản phẩm
                            </span>
                        </td>
                        <td class="px-3 py-3 text-center" style="border:none;">
                            <div style="display:flex;gap:8px;justify-content:center;">
                                <a asp-area="Admin" asp-controller="Category" asp-action="Update" asp-route-id="@cat.Id"
                                   style="width:34px;height:34px;background:#e3f2fd;color:#1565c0;border-radius:8px;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:0.8rem;transition:all 0.2s;"
                                   onmouseover="this.style.background='#1565c0';this.style.color='white'"
                                   onmouseout="this.style.background='#e3f2fd';this.style.color='#1565c0'">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="Category" asp-action="Delete" asp-route-id="@cat.Id"
                                   style="width:34px;height:34px;background:#ffebee;color:#c62828;border-radius:8px;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:0.8rem;transition:all 0.2s;"
                                   onmouseover="this.style.background='#c62828';this.style.color='white'"
                                   onmouseout="this.style.background='#ffebee';this.style.color='#c62828'">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    stt++;
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .btn-add-new {
        display: inline-flex; align-items: center;
        padding: 11px 22px;
        background: linear-gradient(135deg, #1a1a2e, #0f3460);
        color: white; text-decoration: none;
        border-radius: 12px; font-weight: 700; font-size: 0.88rem;
        transition: all 0.3s; box-shadow: 0 4px 12px rgba(15,52,96,0.3);
    }
    .btn-add-new:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(15,52,96,0.4); color: white; }

    .category-card {
        background: white; border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 22px; display: flex; align-items: center; gap: 16px;
        transition: transform 0.2s, box-shadow 0.2s;
        border-left: 4px solid #2e7d32;
    }
    .category-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(46,125,50,0.15); }
    .category-icon-wrap {
        width: 48px; height: 48px;
        background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        color: #2e7d32; font-size: 1.2rem; flex-shrink: 0;
    }
    .category-card-body { flex: 1; }
    .category-name { font-size: 0.95rem; font-weight: 700; color: #1a1a2e; margin: 0 0 4px; }
    .category-product-count { font-size: 0.78rem; color: #888; font-weight: 500; }
    .category-card-actions { display: flex; gap: 6px; }
    .cat-btn {
        width: 32px; height: 32px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.78rem; text-decoration: none; transition: all 0.2s;
    }
    .cat-btn-edit  { background: #e3f2fd; color: #1565c0; }
    .cat-btn-edit:hover  { background: #1565c0; color: white; }
    .cat-btn-delete { background: #ffebee; color: #c62828; }
    .cat-btn-delete:hover { background: #c62828; color: white; }
    .admin-card { background: white; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); overflow: hidden; }
    .admin-card-header { padding: 16px 22px; font-weight: 700; font-size: 0.92rem; color: #1a1a2e; border-bottom: 1px solid #f0f2f5; background: #fafafa; }
</style>
