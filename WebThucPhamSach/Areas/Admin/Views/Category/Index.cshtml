@model IEnumerable<WebThucPhamSach.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
    var productCounts = ViewBag.ProductCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-tags text-warning me-2"></i>Danh sách danh mục</h4>
        <p class="text-muted mb-0">Tổng: <strong>@Model.Count()</strong> danh mục</p>
    </div>
    <a asp-area="Admin" asp-controller="Category" asp-action="Add" class="btn btn-warning">
        <i class="bi bi-plus-circle me-1"></i> Thêm danh mục
    </a>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th style="width:60px">STT</th>
                    <th>Tên danh mục</th>
                    <th class="text-center">Số sản phẩm</th>
                    <th style="width:160px" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>Chưa có danh mục nào
                        </td>
                    </tr>
                }
                @{ int stt = 1; }
                @foreach (var c in Model)
                {
                    var count = productCounts.TryGetValue(c.Id, out var cnt) ? cnt : 0;
                    <tr>
                        <td class="text-muted">@(stt++)</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-success-subtle d-flex align-items-center justify-content-center"
                                     style="width:36px;height:36px;">
                                    <i class="bi bi-tag-fill text-success"></i>
                                </div>
                                <span class="fw-600">@c.Name</span>
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary rounded-pill">@count sản phẩm</span>
                        </td>
                        <td class="text-center">
                            <a asp-area="Admin" asp-controller="Category" asp-action="Update"
                               asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-area="Admin" asp-controller="Category" asp-action="Delete"
                               asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
