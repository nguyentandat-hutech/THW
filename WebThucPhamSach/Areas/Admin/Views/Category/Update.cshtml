@model webthucphamsach.Models.Category
@{
    ViewData["Title"] = "Sửa danh mục | Admin";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" style="color:#2e7d32; text-decoration:none;">
                        <i class="fa-solid fa-tags me-1"></i>Danh mục
                    </a>
                </li>
                <li class="breadcrumb-item active" style="color:#888;">Chỉnh sửa</li>
            </ol>
        </nav>

        <div class="admin-card">
            <div class="admin-card-header" style="background:linear-gradient(135deg,#e3f2fd,#f5f5f5);">
                <i class="fa-solid fa-pen-to-square me-2" style="color:#1565c0;"></i>Chỉnh Sửa Danh Mục
            </div>
            <div class="admin-card-body p-4">
                <form asp-area="Admin" asp-controller="Category" asp-action="Update" method="post" id="editCategoryForm">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-700" style="color:#1a1a2e; font-size:0.88rem;">
                            Tên danh mục <span style="color:#c62828;">*</span>
                        </label>
                        <input asp-for="Name" class="form-control admin-input" id="Name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn-admin-save" style="background:linear-gradient(135deg,#1565c0,#1976d2);" id="saveEditBtn">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Lưu thay đổi
                        </button>
                        <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn-admin-cancel">
                            <i class="fa-solid fa-xmark me-2"></i>Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-card { background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); overflow: hidden; }
    .admin-card-header { padding: 18px 24px; font-weight: 700; font-size: 1rem; color: #1a1a2e; border-bottom: 1px solid #f0f2f5; }
    .admin-input { border: 1.5px solid #e0e0e0; border-radius: 10px; padding: 12px 16px; font-size: 0.92rem; transition: all 0.3s; }
    .admin-input:focus { border-color: #1565c0; box-shadow: 0 0 0 3px rgba(21,101,192,0.1); outline: none; }
    .btn-admin-save {
        display: inline-flex; align-items: center;
        padding: 11px 26px; color: white; border: none; border-radius: 10px;
        font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.3s;
    }
    .btn-admin-save:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(21,101,192,0.35); }
    .btn-admin-cancel {
        display: inline-flex; align-items: center;
        padding: 11px 22px; background: #f5f5f5; color: #555;
        border: 1.5px solid #ddd; border-radius: 10px; font-weight: 600; font-size: 0.9rem;
        text-decoration: none; transition: all 0.2s;
    }
    .btn-admin-cancel:hover { background: #eee; color: #333; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
