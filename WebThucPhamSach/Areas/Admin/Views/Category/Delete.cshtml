@model WebThucPhamSach.Models.Category
@{
    ViewData["Title"] = "Xóa danh mục";
    int productCount = ViewBag.ProductCount ?? 0;
}

<div class="d-flex align-items-center mb-4">
    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0 text-danger"><i class="bi bi-trash me-2"></i>Xác nhận xóa danh mục</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="admin-card overflow-hidden">
            <!-- Header cảnh báo -->
            <div class="bg-danger text-white p-4 text-center">
                <i class="bi bi-exclamation-triangle-fill fs-1 mb-2 d-block"></i>
                <h5 class="fw-bold mb-1">Cảnh báo: Xóa cascade!</h5>
                <p class="mb-0 opacity-75">Thao tác này không thể hoàn tác</p>
            </div>

            <div class="p-4">
                <!-- Thông tin danh mục sẽ bị xóa -->
                <div class="p-3 rounded mb-3" style="background:#fff3cd;border:1px solid #ffc107;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-tag-fill text-warning fs-4"></i>
                        <div>
                            <div class="fw-bold">@Model.Name</div>
                            <div class="text-muted small">Mã danh mục: #@Model.Id</div>
                        </div>
                    </div>
                </div>

                <!-- Cảnh báo số sản phẩm bị xóa theo -->
                @if (productCount > 0)
                {
                    <div class="alert alert-danger d-flex align-items-start gap-2">
                        <i class="bi bi-exclamation-octagon-fill mt-1 flex-shrink-0"></i>
                        <div>
                            <strong>Xóa cascade sẽ xóa <u>@productCount sản phẩm</u> trong danh mục này!</strong>
                            <br />
                            <small>Toàn bộ sản phẩm thuộc "@Model.Name" sẽ bị xóa vĩnh viễn.</small>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Danh mục này chưa có sản phẩm nào, có thể xóa an toàn.
                    </div>
                }

                <form asp-area="Admin" asp-controller="Category" asp-action="DeleteConfirmed" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="bi bi-trash-fill me-2"></i>
                            Xác nhận xóa @(productCount > 0 ? $"(và {productCount} sản phẩm)" : "")
                        </button>
                        <a asp-area="Admin" asp-controller="Category" asp-action="Index"
                           class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-x-circle me-1"></i>Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
