@{
    ViewData["Title"] = "Dashboard - Admin";
    int totalProducts  = ViewBag.TotalProducts  ?? 0;
    int totalCategories = ViewBag.TotalCategories ?? 0;
    decimal totalRevenue = ViewBag.TotalRevenue ?? 0m;
    decimal avgPrice = ViewBag.AvgPrice ?? 0m;
}

<!-- Tiêu đề trang -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="fw-800 mb-1" style="font-size:1.6rem; color:#1a1a2e;">Dashboard</h1>
        <p class="text-muted mb-0" style="font-size:0.88rem;">Tổng quan hệ thống GreenFood Organic Store</p>
    </div>
    <span style="font-size:0.8rem; color:#aaa;">
        <i class="fa-solid fa-calendar me-1"></i>@DateTime.Now.ToString("dd/MM/yyyy")
    </span>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="kpi-card kpi-green">
            <div class="kpi-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@totalProducts</div>
                <div class="kpi-label">Tổng sản phẩm</div>
            </div>
            <div class="kpi-trend"><i class="fa-solid fa-arrow-trend-up"></i> Đang bán</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="kpi-card kpi-blue">
            <div class="kpi-icon"><i class="fa-solid fa-tags"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@totalCategories</div>
                <div class="kpi-label">Danh mục</div>
            </div>
            <div class="kpi-trend"><i class="fa-solid fa-folder-open"></i> Phân loại</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="kpi-card kpi-orange">
            <div class="kpi-icon"><i class="fa-solid fa-money-bill-wave"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@String.Format("{0:N0}", totalRevenue)<small>đ</small></div>
                <div class="kpi-label">Tổng giá trị kho</div>
            </div>
            <div class="kpi-trend"><i class="fa-solid fa-chart-line"></i> Tổng cộng</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="kpi-card kpi-purple">
            <div class="kpi-icon"><i class="fa-solid fa-calculator"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@String.Format("{0:N0}", avgPrice)<small>đ</small></div>
                <div class="kpi-label">Giá trung bình</div>
            </div>
            <div class="kpi-trend"><i class="fa-solid fa-equals"></i> Mỗi sản phẩm</div>
        </div>
    </div>
</div>

<!-- Row 2: Bảng danh mục + Sản phẩm mới -->
<div class="row g-3">
    <!-- Thống kê danh mục -->
    <div class="col-lg-5">
        <div class="admin-card h-100">
            <div class="admin-card-header">
                <i class="fa-solid fa-chart-pie me-2"></i>Doanh thu theo Danh mục
            </div>
            <div class="admin-card-body p-0">
                @{
                    var categoryStats = ViewBag.CategoryStats as IEnumerable<dynamic>;
                }
                @if (categoryStats != null && categoryStats.Any())
                {
                    decimal maxRevenue = (decimal)categoryStats.Max(c => (decimal)c.Revenue);
                    foreach (var cat in categoryStats)
                    {
                        decimal pct = maxRevenue > 0 ? (decimal)cat.Revenue / maxRevenue * 100 : 0;
                        <div class="cat-stat-row">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="cat-stat-name">
                                    <i class="fa-solid fa-leaf me-2 text-success"></i>@cat.Name
                                </span>
                                <div class="text-end">
                                    <span class="cat-stat-count">@cat.Count SP</span>
                                    <span class="cat-stat-revenue">@String.Format("{0:N0}", (decimal)cat.Revenue)đ</span>
                                </div>
                            </div>
                            <div class="cat-progress">
                                <div class="cat-progress-bar" style="width: @pct%"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-chart-pie fa-2x mb-2 opacity-25"></i>
                        <p class="small">Chưa có dữ liệu</p>
                    </div>
                }
            </div>
            <div class="admin-card-footer">
                <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="admin-link">
                    Xem tất cả danh mục <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Sản phẩm mới nhất -->
    <div class="col-lg-7">
        <div class="admin-card h-100">
            <div class="admin-card-header">
                <i class="fa-solid fa-clock-rotate-left me-2"></i>Sản phẩm gần đây
            </div>
            <div class="admin-card-body p-0">
                @{
                    var recentProducts = ViewBag.RecentProducts as IEnumerable<webthucphamsach.Models.Product>;
                }
                @if (recentProducts != null && recentProducts.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr style="background:#f8f9fa;">
                                <th class="px-4 py-3" style="font-size:0.78rem; color:#888; font-weight:600; text-transform:uppercase; border:none;">Sản phẩm</th>
                                <th class="px-3 py-3 text-end" style="font-size:0.78rem; color:#888; font-weight:600; text-transform:uppercase; border:none;">Giá</th>
                                <th class="px-3 py-3 text-center" style="font-size:0.78rem; color:#888; font-weight:600; text-transform:uppercase; border:none; width:90px;">Sửa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in recentProducts)
                            {
                                <tr>
                                    <td class="px-4 py-3" style="border-color:#f0f0f0;">
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@p.ImageUrl" alt="@p.Name"
                                                 style="width:40px;height:40px;object-fit:cover;border-radius:8px;"
                                                 onerror="this.src='https://placehold.co/40x40?text=F'" />
                                            <span style="font-weight:600;font-size:0.88rem;color:#1a1a2e;">
                                                @(p.Name.Length > 35 ? p.Name.Substring(0,35) + "..." : p.Name)
                                            </span>
                                        </div>
                                    </td>
                                    <td class="px-3 py-3 text-end" style="border-color:#f0f0f0; font-weight:700; color:#e65100; font-size:0.9rem;">
                                        @String.Format("{0:N0}", p.Price)đ
                                    </td>
                                    <td class="px-3 py-3 text-center" style="border-color:#f0f0f0;">
                                        <a asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@p.Id"
                                           style="width:32px;height:32px;background:#e3f2fd;color:#1565c0;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;font-size:0.78rem;text-decoration:none;transition:all 0.2s;"
                                           onmouseover="this.style.background='#1565c0';this.style.color='white'"
                                           onmouseout="this.style.background='#e3f2fd';this.style.color='#1565c0'">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="admin-card-footer">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="admin-link">
                    Quản lý tất cả sản phẩm <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mt-1">
    <div class="col-12">
        <div class="admin-card">
            <div class="admin-card-header">
                <i class="fa-solid fa-bolt me-2"></i>Thao tác nhanh
            </div>
            <div class="admin-card-body">
                <div class="d-flex flex-wrap gap-3">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="quick-action-btn qa-green">
                        <i class="fa-solid fa-plus-circle"></i>
                        <span>Thêm sản phẩm mới</span>
                    </a>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Add" class="quick-action-btn qa-blue">
                        <i class="fa-solid fa-folder-plus"></i>
                        <span>Thêm danh mục mới</span>
                    </a>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="quick-action-btn qa-orange">
                        <i class="fa-solid fa-list"></i>
                        <span>Xem danh sách sản phẩm</span>
                    </a>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="quick-action-btn qa-purple">
                        <i class="fa-solid fa-tags"></i>
                        <span>Quản lý danh mục</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* KPI Cards */
    .kpi-card {
        background: white; border-radius: 16px; padding: 22px;
        display: flex; align-items: center; gap: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        position: relative; overflow: hidden;
        border-left: 4px solid transparent;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
    .kpi-green { border-left-color: #2e7d32; }
    .kpi-blue  { border-left-color: #1565c0; }
    .kpi-orange{ border-left-color: #e65100; }
    .kpi-purple{ border-left-color: #6a1b9a; }
    .kpi-icon {
        width: 52px; height: 52px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; flex-shrink: 0;
    }
    .kpi-green .kpi-icon  { background: #e8f5e9; color: #2e7d32; }
    .kpi-blue  .kpi-icon  { background: #e3f2fd; color: #1565c0; }
    .kpi-orange .kpi-icon { background: #fbe9e7; color: #e65100; }
    .kpi-purple .kpi-icon { background: #f3e5f5; color: #6a1b9a; }
    .kpi-body { flex: 1; }
    .kpi-value { font-size: 1.6rem; font-weight: 800; color: #1a1a2e; line-height: 1; }
    .kpi-value small { font-size: 0.9rem; font-weight: 500; color: #999; margin-left: 2px; }
    .kpi-label { font-size: 0.8rem; color: #888; margin-top: 4px; font-weight: 500; }
    .kpi-trend { font-size: 0.72rem; color: #bbb; position: absolute; bottom: 12px; right: 14px; }

    /* Admin Cards */
    .admin-card { background: white; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); overflow: hidden; }
    .admin-card-header {
        padding: 16px 22px; font-weight: 700; font-size: 0.92rem;
        color: #1a1a2e; border-bottom: 1px solid #f0f2f5;
        background: #fafafa;
    }
    .admin-card-body { padding: 20px 22px; }
    .admin-card-footer {
        padding: 12px 22px; border-top: 1px solid #f0f2f5;
        background: #fafafa;
    }
    .admin-link { color: #2e7d32; font-size: 0.82rem; font-weight: 600; text-decoration: none; }
    .admin-link:hover { color: #1b5e20; }

    /* Category stats */
    .cat-stat-row { padding: 14px 22px; border-bottom: 1px solid #f5f5f5; }
    .cat-stat-row:last-child { border-bottom: none; }
    .cat-stat-name { font-size: 0.85rem; font-weight: 600; color: #333; }
    .cat-stat-count { font-size: 0.75rem; color: #888; margin-right: 10px; }
    .cat-stat-revenue { font-size: 0.82rem; font-weight: 700; color: #e65100; }
    .cat-progress { height: 5px; background: #f0f2f5; border-radius: 3px; overflow: hidden; }
    .cat-progress-bar {
        height: 100%; border-radius: 3px;
        background: linear-gradient(90deg, #2e7d32, #66bb6a);
        transition: width 0.8s ease;
    }

    /* Quick actions */
    .quick-action-btn {
        display: inline-flex; align-items: center; gap: 10px;
        padding: 12px 22px; border-radius: 12px;
        font-size: 0.88rem; font-weight: 700; text-decoration: none;
        transition: all 0.3s ease;
    }
    .qa-green  { background: #e8f5e9; color: #2e7d32; border: 1.5px solid #c8e6c9; }
    .qa-blue   { background: #e3f2fd; color: #1565c0; border: 1.5px solid #bbdefb; }
    .qa-orange { background: #fbe9e7; color: #e65100; border: 1.5px solid #ffccbc; }
    .qa-purple { background: #f3e5f5; color: #6a1b9a; border: 1.5px solid #e1bee7; }
    .quick-action-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,0.12); }
    .qa-green:hover  { background: #2e7d32; color: white; }
    .qa-blue:hover   { background: #1565c0; color: white; }
    .qa-orange:hover { background: #e65100; color: white; }
    .qa-purple:hover { background: #6a1b9a; color: white; }
</style>
