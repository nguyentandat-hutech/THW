@model IEnumerable<WebThucPhamSach.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "_Layout_Admin";
    var currentFilter = ViewBag.CurrentFilter as string;
    var totalOrders = (int)ViewBag.TotalOrders;
    var pendingOrders = (int)ViewBag.PendingOrders;
    var deliveredOrders = (int)ViewBag.DeliveredOrders;
    var totalRevenue = (decimal)ViewBag.TotalRevenue;
}

<div class="d-flex align-items-center mb-4">
    <h2 class="fw-bold mb-0 text-dark">Quản lý Đơn hàng</h2>
    <span class="ms-3 badge bg-secondary bg-opacity-10 text-secondary fs-7 px-3 py-2 rounded-pill">
        Tổng số: @Model.Count() đơn
    </span>
</div>

<!-- Grid thống kê nhanh cho Admin -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-3 bg-white p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3 me-3">
                    <i class="bi bi-receipt fs-4"></i>
                </div>
                <div>
                    <span class="text-secondary fs-7 d-block">Tổng số đơn</span>
                    <h4 class="fw-bold mb-0">@totalOrders</h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-3 bg-white p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-3 me-3">
                    <i class="bi bi-clock-history fs-4"></i>
                </div>
                <div>
                    <span class="text-secondary fs-7 d-block">Chờ duyệt</span>
                    <h4 class="fw-bold mb-0 text-warning">@pendingOrders</h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-3 bg-white p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="bg-success bg-opacity-10 text-success rounded-3 p-3 me-3">
                    <i class="bi bi-check-circle fs-4"></i>
                </div>
                <div>
                    <span class="text-secondary fs-7 d-block">Đã hoàn thành</span>
                    <h4 class="fw-bold mb-0 text-success">@deliveredOrders</h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-3 bg-white p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="bg-info bg-opacity-10 text-info rounded-3 p-3 me-3">
                    <i class="bi bi-currency-dollar fs-4"></i>
                </div>
                <div>
                    <span class="text-secondary fs-7 d-block">Doanh thu sạch</span>
                    <h4 class="fw-bold mb-0 text-info fs-5">@totalRevenue.ToString("#,##0") đ</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Các bộ lọc đơn hàng -->
<div class="mb-4 d-flex flex-wrap gap-2">
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" 
       class="btn rounded-pill px-4 py-2 @(string.IsNullOrEmpty(currentFilter) ? "btn-success" : "btn-outline-success")">
        Tất cả đơn
    </a>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" asp-route-statusFilter="Chờ duyệt" 
       class="btn rounded-pill px-4 py-2 @(currentFilter == "Chờ duyệt" ? "btn-warning text-dark" : "btn-outline-warning text-dark")">
        Chờ duyệt
    </a>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" asp-route-statusFilter="Đã duyệt" 
       class="btn rounded-pill px-4 py-2 @(currentFilter == "Đã duyệt" ? "btn-info text-white" : "btn-outline-info")">
        Đã duyệt
    </a>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" asp-route-statusFilter="Đang giao" 
       class="btn rounded-pill px-4 py-2 @(currentFilter == "Đang giao" ? "btn-primary" : "btn-outline-primary")">
        Đang giao
    </a>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" asp-route-statusFilter="Đã giao" 
       class="btn rounded-pill px-4 py-2 @(currentFilter == "Đã giao" ? "btn-success" : "btn-outline-success")">
        Đã giao
    </a>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" asp-route-statusFilter="Đã hủy" 
       class="btn rounded-pill px-4 py-2 @(currentFilter == "Đã hủy" ? "btn-danger" : "btn-outline-danger")">
        Đã hủy
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Bảng đơn hàng -->
@if (Model == null || !Model.Any())
{
    <div class="text-center py-5 shadow-sm rounded-3 bg-white border border-light">
        <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
        <h5 class="fw-bold text-secondary mt-3">Không tìm thấy đơn hàng nào</h5>
        <p class="text-muted mb-0">Hệ thống chưa ghi nhận đơn hàng nào ở trạng thái này.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-3 bg-white overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover table-align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th scope="col" class="py-3 ps-4" style="width: 100px;">Mã đơn</th>
                        <th scope="col" class="py-3">Khách hàng</th>
                        <th scope="col" class="py-3">Ngày đặt</th>
                        <th scope="col" class="py-3">Số điện thoại</th>
                        <th scope="col" class="py-3">Địa chỉ nhận</th>
                        <th scope="col" class="py-3 text-end" style="width: 130px;">Tổng tiền</th>
                        <th scope="col" class="py-3 text-center" style="width: 140px;">Trạng thái</th>
                        <th scope="col" class="py-3 text-center" style="width: 120px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-bold text-dark">
                                #@order.Id
                            </td>
                            <td class="py-3 fw-semibold">
                                @(order.ApplicationUser?.FullName ?? "Khách hàng")
                            </td>
                            <td class="py-3 text-secondary fs-7">
                                @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="py-3">
                                @order.PhoneNumber
                            </td>
                            <td class="py-3 text-truncate fs-7" style="max-width: 200px;" title="@order.ShippingAddress">
                                @order.ShippingAddress
                            </td>
                            <td class="py-3 text-end fw-bold text-success">
                                @order.TotalPrice.ToString("#,##0") đ
                            </td>
                            <td class="py-3 text-center">
                                @{
                                    string badgeClass = order.Status switch
                                    {
                                        "Chờ duyệt" => "bg-warning text-dark",
                                        "Đã duyệt" => "bg-info text-white",
                                        "Đang giao" => "bg-primary text-white",
                                        "Đã giao" => "bg-success text-white",
                                        "Đã hủy" => "bg-danger text-white",
                                        _ => "bg-secondary text-white"
                                    };
                                }
                                <span class="badge @badgeClass px-3 py-2 rounded-pill fw-semibold fs-8">
                                    @order.Status
                                </span>
                            </td>
                            <td class="py-3 text-center">
                                <a asp-area="Admin" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" 
                                   class="btn btn-outline-success btn-sm rounded-pill px-3 fw-semibold">
                                    <i class="bi bi-pencil-square me-1"></i>Xử lý
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <style>
        .table-align-middle td {
            vertical-align: middle;
        }
        .fs-7 {
            font-size: 0.85rem;
        }
        .fs-8 {
            font-size: 0.78rem;
        }
    </style>
}
