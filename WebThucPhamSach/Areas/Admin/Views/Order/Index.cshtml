@model IEnumerable<webthucphamsach.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="m-0 text-dark fw-bold"><i class="fa-solid fa-truck-fast text-success me-2"></i>Quản lý Đơn hàng</h4>
        <small class="text-muted">Danh sách và trạng thái các đơn đặt hàng từ khách hàng.</small>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 fw-semibold text-dark"><i class="fa-solid fa-list me-2"></i>Danh sách Đơn hàng (@Model.Count())</h5>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-receipt text-muted" style="font-size: 4rem; opacity: 0.2;"></i>
            <h5 class="text-secondary mt-3">Chưa có đơn hàng nào được đặt.</h5>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-4" style="width: 80px;">Mã ĐH</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Địa chỉ giao hàng</th>
                        <th class="text-end" style="width: 150px;">Tổng tiền</th>
                        <th class="text-center" style="width: 160px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-success">
                                #@item.Id
                            </td>
                            <td>
                                <div class="fw-semibold text-dark">@(item.ApplicationUser?.FullName ?? "Khách vãng lai")</div>
                                <small class="text-muted">@(item.ApplicationUser?.Email ?? "N/A")</small>
                            </td>
                            <td>
                                @item.OrderDate.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td>
                                <div class="text-truncate" style="max-width: 300px;" title="@item.ShippingAddress">
                                    @item.ShippingAddress
                                </div>
                            </td>
                            <td class="text-end fw-bold text-danger">
                                @item.TotalPrice.ToString("N0") đ
                            </td>
                            <td class="text-center">
                                <div class="d-inline-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-success btn-sm rounded-3 d-inline-flex align-items-center gap-1">
                                        <i class="fa-solid fa-eye"></i> Chi tiết
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này? Thao tác này sẽ xóa mọi chi tiết liên quan và không thể khôi phục!')" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 d-inline-flex align-items-center gap-1">
                                            <i class="fa-solid fa-trash-can"></i> Xóa
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
