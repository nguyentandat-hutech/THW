@model WebThucPhamSach.Models.Order
@{
    ViewData["Title"] = "Xử lý Đơn hàng #" + Model.Id;
    Layout = "_Layout_Admin";
}

<div class="d-flex align-items-center mb-4">
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle me-3" style="width: 35px; height: 35px; display: inline-flex; align-items: center; justify-content: center;">
        <i class="bi bi-arrow-left fs-5"></i>
    </a>
    <h2 class="fw-bold mb-0 text-dark">Xử lý Đơn hàng #@Model.Id</h2>
    <span class="ms-3 text-muted">Đặt ngày @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    <!-- Cột sản phẩm và thông tin vận chuyển -->
    <div class="col-lg-8">
        <!-- Thông tin vận chuyển -->
        <div class="card border-0 shadow-sm rounded-3 bg-white p-4 mb-4">
            <h5 class="fw-bold text-dark mb-3 border-bottom border-light pb-2">
                <i class="bi bi-truck text-success me-2"></i>Thông tin nhận hàng
            </h5>
            <div class="row g-3">
                <div class="col-sm-6">
                    <span class="text-secondary fs-7 d-block">Tên người nhận:</span>
                    <span class="fw-bold text-dark">@Model.ApplicationUser?.FullName</span>
                </div>
                <div class="col-sm-6">
                    <span class="text-secondary fs-7 d-block">Số điện thoại liên hệ:</span>
                    <span class="fw-bold text-dark">@Model.PhoneNumber</span>
                </div>
                <div class="col-12">
                    <span class="text-secondary fs-7 d-block">Địa chỉ nhận hàng:</span>
                    <span class="text-dark">@Model.ShippingAddress</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="col-12">
                        <div class="bg-light p-3 rounded-3 border border-light">
                            <span class="text-secondary fs-7 d-block">Ghi chú giao hàng:</span>
                            <span class="text-muted italic">"@Model.Notes"</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Bảng sản phẩm -->
        <div class="card border-0 shadow-sm rounded-3 bg-white overflow-hidden">
            <div class="card-header bg-light py-3 px-4">
                <h5 class="fw-bold text-dark mb-0"><i class="bi bi-list-check me-2"></i>Sản phẩm đã đặt</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-align-middle mb-0">
                    <thead>
                        <tr class="bg-light text-secondary">
                            <th scope="col" class="py-2 ps-4">Sản phẩm</th>
                            <th scope="col" class="py-2 text-end" style="width: 120px;">Đơn giá</th>
                            <th scope="col" class="py-2 text-center" style="width: 100px;">Số lượng</th>
                            <th scope="col" class="py-2 text-end" style="width: 120px;">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in Model.OrderDetails)
                        {
                            var itemTotal = detail.Price * detail.Quantity;
                            <tr class="border-bottom border-light">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-3 overflow-hidden bg-light border border-light flex-shrink-0" style="width: 50px; height: 50px;">
                                            <img src="~/images/@(string.IsNullOrEmpty(detail.Product.ImageUrl) ? "no-image.jpg" : detail.Product.ImageUrl)" 
                                                 class="w-100 h-100 object-fit-cover" 
                                                 alt="@detail.Product.Name" 
                                                 onerror="this.src='/images/no-image.jpg';" />
                                        </div>
                                        <div class="ms-3">
                                            <span class="fw-bold text-dark d-block">
                                                @detail.Product.Name
                                            </span>
                                            <span class="badge bg-light text-secondary border border-light fs-8">Nông sản sạch</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-end py-3 fw-semibold text-secondary">
                                    @detail.Price.ToString("#,##0") đ
                                </td>
                                <td class="text-center py-3 fw-bold">
                                    @detail.Quantity
                                </td>
                                <td class="text-end py-3 fw-bold text-success">
                                    @itemTotal.ToString("#,##0") đ
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Cột cập nhật trạng thái đơn hàng -->
    <div class="col-lg-4">
        <!-- Form cập nhật trạng thái -->
        <div class="card border-0 shadow-sm rounded-3 bg-white p-4 mb-4">
            <h5 class="fw-bold text-dark mb-3 border-bottom border-light pb-2">Xử lý trạng thái</h5>
            
            <div class="mb-3">
                <span class="text-secondary fs-7 d-block">Trạng thái hiện tại:</span>
                @{
                    string badgeClass = Model.Status switch
                    {
                        "Chờ duyệt" => "bg-warning text-dark",
                        "Đã duyệt" => "bg-info text-white",
                        "Đang giao" => "bg-primary text-white",
                        "Đã giao" => "bg-success text-white",
                        "Đã hủy" => "bg-danger text-white",
                        _ => "bg-secondary text-white"
                    };
                }
                <span class="badge @badgeClass px-3 py-2 rounded-pill fw-bold fs-7 mt-1">
                    @Model.Status
                </span>
            </div>

            <!-- Form cập nhật -->
            <form asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                
                <div class="mb-4">
                    <label for="status" class="form-label fw-semibold text-dark">Chuyển sang trạng thái:</label>
                    <select name="status" id="status" class="form-select rounded-3">
                        <option value="Chờ duyệt" selected="@(Model.Status == "Chờ duyệt")">Chờ duyệt</option>
                        <option value="Đã duyệt" selected="@(Model.Status == "Đã duyệt")">Đã duyệt (Đóng gói)</option>
                        <option value="Đang giao" selected="@(Model.Status == "Đang giao")">Đang giao hàng</option>
                        <option value="Đã giao" selected="@(Model.Status == "Đã giao")">Đã giao hàng (Hoàn thành)</option>
                        <option value="Đã hủy" selected="@(Model.Status == "Đã hủy")">Đã hủy</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-success w-100 rounded-pill py-2-5 fw-bold shadow-sm">
                    <i class="bi bi-save me-2"></i>Cập nhật trạng thái
                </button>
            </form>
        </div>

        <!-- Hóa đơn tóm tắt -->
        <div class="card border-0 shadow-sm rounded-3 bg-white p-4">
            <h5 class="fw-bold text-dark mb-3 border-bottom border-light pb-2">Giá trị đơn hàng</h5>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-secondary">Tạm tính</span>
                <span class="fw-semibold">@Model.TotalPrice.ToString("#,##0") đ</span>
            </div>
            <div class="d-flex justify-content-between mb-3">
                <span class="text-secondary">Phí vận chuyển</span>
                <span class="text-success fw-semibold">Miễn phí</span>
            </div>
            <hr class="my-2 border-light">
            <div class="d-flex justify-content-between align-items-center mb-0 mt-2">
                <span class="fw-bold text-dark">Thành tiền</span>
                <span class="fw-extrabold text-success fs-5">@Model.TotalPrice.ToString("#,##0") đ</span>
            </div>
            <span class="badge bg-light text-secondary border border-light w-100 py-2 rounded-3 mt-3 fw-normal fs-7">
                <i class="bi bi-cash-stack me-2 text-success"></i>Thanh toán COD
            </span>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .table-align-middle td {
            vertical-align: middle;
        }
        .py-2-5 {
            padding-top: 0.65rem;
            padding-bottom: 0.65rem;
        }
        .object-fit-cover {
            object-fit: cover;
        }
        .italic {
            font-style: italic;
        }
        .fs-7 {
            font-size: 0.85rem;
        }
        .fs-8 {
            font-size: 0.75rem;
        }
        .fw-extrabold {
            font-weight: 800;
        }
    </style>
}
