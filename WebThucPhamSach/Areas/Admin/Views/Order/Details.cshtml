@model webthucphamsach.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<div class="mb-4">
    <a asp-action="Index" class="text-success text-decoration-none fw-semibold d-inline-flex align-items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i>
        <span>Quay lại danh sách đơn hàng</span>
    </a>
</div>

<div class="row g-4">
    <!-- Cột Trái: Thông tin Đơn hàng & Sản phẩm -->
    <div class="col-lg-8">
        <!-- Chi tiết sản phẩm -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="m-0 fw-semibold text-dark"><i class="fa-solid fa-basket-shopping text-success me-2"></i>Sản phẩm đã đặt</h5>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th class="ps-4" style="width: 80px;">Ảnh</th>
                            <th>Tên thực phẩm</th>
                            <th class="text-end" style="width: 130px;">Đơn giá</th>
                            <th class="text-center" style="width: 100px;">Số lượng</th>
                            <th class="text-end" style="width: 140px;">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in Model.OrderDetails)
                        {
                            var itemTotal = detail.Price * detail.Quantity;
                            <tr>
                                <td class="ps-4">
                                    <div class="rounded-3 overflow-hidden border border-light" style="width: 50px; height: 50px;">
                                        <img src="@(string.IsNullOrEmpty(detail.Product?.ImageUrl) ? "https://images.unsplash.com/photo-1610348725531-843dff14f9da?w=200&auto=format&fit=crop&q=60" : detail.Product.ImageUrl)" 
                                             alt="@(detail.Product?.Name ?? "Sản phẩm")" 
                                             class="w-100 h-100" 
                                             style="object-fit: cover;" />
                                    </div>
                                </td>
                                <td>
                                    <h6 class="mb-0 fw-semibold text-dark">@(detail.Product?.Name ?? "Sản phẩm không xác định (Đã xóa)")</h6>
                                    <small class="text-muted">Mã SP: #@detail.ProductId</small>
                                </td>
                                <td class="text-end text-secondary">
                                    @detail.Price.ToString("N0") đ
                                </td>
                                <td class="text-center fw-semibold text-dark">
                                    @detail.Quantity
                                </td>
                                <td class="text-end fw-bold text-success">
                                    @itemTotal.ToString("N0") đ
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-white border-0 py-4 pe-4 text-end">
                <span class="text-secondary me-2">Tổng số tiền thanh toán:</span>
                <span class="fs-4 fw-extrabold text-danger">@Model.TotalPrice.ToString("N0") đ</span>
            </div>
        </div>
    </div>

    <!-- Cột Phải: Thông tin Người mua & Địa chỉ giao hàng -->
    <div class="col-lg-4">
        <!-- Thông tin Khách hàng -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h5 class="fw-semibold text-success mb-4 pb-2 border-bottom">
                <i class="fa-solid fa-user me-2"></i>Thông tin Khách hàng
            </h5>
            <div class="mb-3">
                <span class="text-secondary small d-block">Tên khách hàng</span>
                <span class="fw-bold text-dark fs-6">@(Model.ApplicationUser?.FullName ?? "Khách vãng lai")</span>
            </div>
            <div class="mb-3">
                <span class="text-secondary small d-block">Email liên hệ</span>
                <span class="fw-semibold text-dark">@(Model.ApplicationUser?.Email ?? "Không khả dụng")</span>
            </div>
            <div class="mb-3">
                <span class="text-secondary small d-block">Số điện thoại</span>
                <span class="fw-semibold text-dark">@(Model.ApplicationUser?.PhoneNumber ?? "Không khả dụng")</span>
            </div>
            <div class="mb-0">
                <span class="text-secondary small d-block">Độ tuổi</span>
                <span class="fw-semibold text-dark">@(Model.ApplicationUser?.Age?.ToString() ?? "N/A")</span>
            </div>
        </div>

        <!-- Thông tin giao hàng -->
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h5 class="fw-semibold text-success mb-4 pb-2 border-bottom">
                <i class="fa-solid fa-location-dot me-2"></i>Địa chỉ & Ghi chú
            </h5>
            <div class="mb-3">
                <span class="text-secondary small d-block">Ngày đặt hàng</span>
                <span class="fw-bold text-dark">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="mb-3">
                <span class="text-secondary small d-block text-danger fw-bold">Địa chỉ giao hàng</span>
                <span class="fw-semibold text-dark d-block p-2 bg-light rounded-3 border" style="line-height:1.5;">@Model.ShippingAddress</span>
            </div>
            <div class="mb-0">
                <span class="text-secondary small d-block">Ghi chú từ khách</span>
                <div class="p-2 bg-light rounded-3 border text-secondary" style="font-style: italic; font-size: 0.9rem; min-height: 50px;">
                    @(string.IsNullOrEmpty(Model.Notes) ? "Không có ghi chú" : Model.Notes)
                </div>
            </div>
        </div>
    </div>
</div>
