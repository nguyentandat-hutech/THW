@model WebThucPhamSach.Models.Product
@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="d-flex align-items-center mb-4">
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0 text-danger"><i class="bi bi-trash me-2"></i>Xác nhận xóa sản phẩm</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="admin-card overflow-hidden">
            <div class="bg-danger text-white p-4 text-center">
                <i class="bi bi-exclamation-triangle-fill fs-1 mb-2 d-block"></i>
                <h5 class="fw-bold mb-1">Bạn có chắc muốn xóa?</h5>
                <p class="mb-0 opacity-75 small">Thao tác này không thể hoàn tác!</p>
            </div>
            <div class="p-4">
                <div class="d-flex align-items-center gap-3 mb-4 p-3 bg-light rounded">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="~/images/@Model.ImageUrl" alt="@Model.Name"
                             class="rounded" style="width:70px;height:70px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded bg-secondary d-flex align-items-center justify-content-center"
                             style="width:70px;height:70px;">
                            <i class="bi bi-image text-white fs-3"></i>
                        </div>
                    }
                    <div>
                        <h6 class="fw-bold mb-1">@Model.Name</h6>
                        <div class="text-muted small">Danh mục: @ViewBag.CategoryName</div>
                        <div class="text-danger fw-bold">@Model.Price.ToString("N0") ₫</div>
                    </div>
                </div>

                <form asp-area="Admin" asp-controller="Product" asp-action="DeleteConfirmed" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash-fill me-2"></i>Xác nhận xóa
                        </button>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                           class="btn btn-outline-secondary">Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
