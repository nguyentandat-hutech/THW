@model webthucphamsach.Models.Product
@{
    ViewData["Title"] = "Xóa sản phẩm | Admin";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="delete-card">
                <div class="delete-card-header">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>Xác nhận Xóa Sản phẩm
                </div>
                <div class="delete-card-body">
                    <p class="delete-warning">Bạn có chắc chắn muốn xóa sản phẩm sau đây không? Hành động này <strong>không thể hoàn tác</strong>.</p>

                    <div class="product-info-box">
                        <img src="@Model.ImageUrl" alt="@Model.Name"
                             class="delete-product-img"
                             onerror="this.src='/images/default-food.jpg'" />
                        <div class="product-details">
                            <h4 class="fw-bold">@Model.Name</h4>
                            <p class="text-muted small mb-1">
                                <i class="fa-solid fa-tag me-1 text-success"></i>@ViewBag.CategoryName
                            </p>
                            <p class="delete-price">@String.Format("{0:N0}", Model.Price)đ</p>
                        </div>
                    </div>

                    <form asp-area="Admin" asp-controller="Product" asp-action="Delete"
                          asp-route-id="@Model.Id" method="post" id="deleteForm">
                        <div class="delete-actions">
                            <button type="submit" class="btn btn-danger-confirm" id="confirmDeleteBtn">
                                <i class="fa-solid fa-trash me-2"></i>Xóa Vĩnh Viễn
                            </button>
                            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                               class="btn btn-cancel-delete">
                                <i class="fa-solid fa-arrow-left me-2"></i>Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .delete-card { background: white; border-radius: 16px; box-shadow: 0 8px 30px rgba(0,0,0,0.12); overflow: hidden; }
    .delete-card-header {
        background: linear-gradient(135deg, #b71c1c, #c62828);
        color: white; font-size: 1.1rem; font-weight: 700; padding: 20px 30px;
    }
    .delete-card-body { padding: 30px; }
    .delete-warning { color: #555; font-size: 0.95rem; line-height: 1.6; }
    .product-info-box {
        display: flex; align-items: center; gap: 20px;
        background: #fff8e1; border: 1px solid #ffe082; border-radius: 12px;
        padding: 20px; margin: 20px 0;
    }
    .delete-product-img { width: 80px; height: 80px; object-fit: cover; border-radius: 10px; flex-shrink: 0; }
    .delete-price { font-weight: 800; color: #c62828; font-size: 1.1rem; margin: 0; }
    .delete-actions { display: flex; gap: 12px; margin-top: 20px; }
    .btn-danger-confirm {
        background: linear-gradient(135deg, #b71c1c, #c62828);
        color: white; border: none; border-radius: 10px; padding: 12px 28px; font-weight: 700; transition: all 0.3s;
    }
    .btn-danger-confirm:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(198,40,40,0.4); color: white; }
    .btn-cancel-delete {
        background: #f5f5f5; color: #555; border: 1.5px solid #ddd;
        border-radius: 10px; padding: 12px 24px; font-weight: 600; text-decoration: none;
        display: inline-flex; align-items: center; transition: all 0.2s;
    }
    .btn-cancel-delete:hover { background: #eeeeee; color: #333; }
</style>
