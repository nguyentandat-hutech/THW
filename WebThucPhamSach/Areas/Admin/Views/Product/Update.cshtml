@model webthucphamsach.Models.Product
@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm | Admin";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="text-success">
                            <i class="fa-solid fa-boxes-stacked me-1"></i>Quản lý sản phẩm
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Chỉnh sửa sản phẩm</li>
                </ol>
            </nav>

            <div class="form-card">
                <div class="form-card-header">
                    <i class="fa-solid fa-pen-to-square me-2"></i>Chỉnh Sửa Sản Phẩm
                </div>
                <div class="form-card-body">
                    <form asp-area="Admin" asp-controller="Product" asp-action="Update"
                          method="post" enctype="multipart/form-data" id="editProductForm">
                        <input asp-for="Id" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4" role="alert"></div>

                        <div class="row g-3">
                            <!-- Xem trước ảnh hiện tại -->
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="col-12">
                                    <label class="form-label">Hình ảnh hiện tại</label>
                                    <div>
                                        <img src="@Model.ImageUrl" alt="@Model.Name"
                                             class="current-img"
                                             onerror="this.src='/images/default-food.jpg'" />
                                    </div>
                                </div>
                            }

                            <div class="col-12">
                                <label asp-for="Name" class="form-label required-label">Tên sản phẩm</label>
                                <input asp-for="Name" class="form-control" id="Name" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label required-label">Giá bán (VNĐ)</label>
                                <div class="input-group">
                                    <input asp-for="Price" class="form-control" type="number" min="0" id="Price" />
                                    <span class="input-group-text">đ</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label required-label">Danh mục</label>
                                <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                                        class="form-select" id="CategoryId">
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label">Mô tả sản phẩm</label>
                                <textarea asp-for="Description" class="form-control" rows="4" id="Description"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Thay đổi hình ảnh (để trống nếu giữ nguyên)</label>
                                <input type="file" name="ImageFile" class="form-control" accept="image/*"
                                       id="ImageFile" onchange="previewImage(this)" />
                                <div id="imagePreview" class="mt-2" style="display:none;">
                                    <img id="previewImg" src="" alt="Preview" class="img-preview" />
                                </div>
                            </div>
                        </div>

                        <div class="form-actions mt-4">
                            <button type="submit" class="btn btn-admin-submit" id="submitEditBtn">
                                <i class="fa-solid fa-floppy-disk me-2"></i>Lưu thay đổi
                            </button>
                            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                               class="btn btn-admin-cancel">
                                <i class="fa-solid fa-xmark me-2"></i>Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-card { background: white; border-radius: 16px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); overflow: hidden; }
    .form-card-header {
        background: linear-gradient(135deg, #1565c0, #1976d2);
        color: white; font-size: 1.2rem; font-weight: 700; padding: 20px 30px;
    }
    .form-card-body { padding: 30px; }
    .form-label { font-weight: 600; color: #1565c0; font-size: 0.88rem; margin-bottom: 6px; }
    .required-label::after { content: " *"; color: #c62828; }
    .form-control, .form-select {
        border: 1.5px solid #bbdefb; border-radius: 10px;
        padding: 11px 15px; font-size: 0.92rem; transition: all 0.3s;
    }
    .form-control:focus, .form-select:focus {
        border-color: #1565c0; box-shadow: 0 0 0 3px rgba(21,101,192,0.12); outline: none;
    }
    .btn-admin-submit {
        background: linear-gradient(135deg, #1565c0, #1976d2);
        color: white; border: none; border-radius: 10px; padding: 12px 30px;
        font-weight: 700; font-size: 0.95rem; transition: all 0.3s;
    }
    .btn-admin-submit:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(21,101,192,0.35); color: white; }
    .btn-admin-cancel {
        background: #f5f5f5; color: #555; border: 1.5px solid #ddd;
        border-radius: 10px; padding: 12px 24px; font-weight: 600; font-size: 0.95rem; text-decoration: none;
        display: inline-flex; align-items: center; transition: all 0.2s;
    }
    .btn-admin-cancel:hover { background: #eeeeee; color: #333; }
    .form-actions { display: flex; gap: 12px; align-items: center; }
    .img-preview, .current-img {
        max-width: 180px; max-height: 180px; object-fit: cover;
        border-radius: 10px; border: 2px solid #bbdefb;
    }
    .input-group-text { background: #e3f2fd; border: 1.5px solid #bbdefb; color: #1565c0; font-weight: 700; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('imagePreview').style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
