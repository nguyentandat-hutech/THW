@model WebThucPhamSach.Models.Product
@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<div class="d-flex align-items-center mb-4">
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-pencil-square text-primary me-2"></i>Cập nhật sản phẩm</h4>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="admin-card p-4">
            <form asp-area="Admin" asp-controller="Product" asp-action="Update" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-600"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-600"></label>
                        <div class="input-group">
                            <input asp-for="Price" class="form-control" />
                            <span class="input-group-text">₫</span>
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label fw-600"></label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-600"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-600">Ảnh mới (để trống nếu giữ ảnh cũ)</label>
                    <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-1"></i> Lưu thay đổi
                    </button>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                       class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Ảnh hiện tại -->
    <div class="col-lg-4">
        <div class="admin-card p-4 text-center">
            <p class="text-muted small mb-2">Ảnh hiện tại</p>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="~/images/@Model.ImageUrl" alt="@Model.Name"
                     id="imgPreview"
                     class="img-fluid rounded" style="max-height:200px;object-fit:cover;" />
            }
            else
            {
                <div class="rounded bg-light d-flex align-items-center justify-content-center" style="height:200px;">
                    <div class="text-muted">
                        <i class="bi bi-image fs-1 d-block mb-2"></i>
                        <small>Chưa có ảnh</small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('imageFile').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(ev) {
                    const img = document.getElementById('imgPreview');
                    if (img) img.src = ev.target.result;
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
