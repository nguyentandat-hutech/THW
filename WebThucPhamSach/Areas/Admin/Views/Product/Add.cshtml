@model webthucphamsach.Models.Product
@{
    ViewData["Title"] = "Thêm sản phẩm mới | Admin";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="text-success">
                            <i class="fa-solid fa-boxes-stacked me-1"></i>Quản lý sản phẩm
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Thêm sản phẩm mới</li>
                </ol>
            </nav>

            <div class="form-card">
                <div class="form-card-header">
                    <i class="fa-solid fa-plus-circle me-2"></i>Thêm Sản Phẩm Mới
                </div>
                <div class="form-card-body">
                    <form asp-area="Admin" asp-controller="Product" asp-action="Add"
                          method="post" enctype="multipart/form-data" id="addProductForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Name" class="form-label required-label">Tên sản phẩm</label>
                                <input asp-for="Name" class="form-control" placeholder="VD: Rau cải bó xôi hữu cơ Đà Lạt" id="Name" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label required-label">Giá bán (VNĐ)</label>
                                <div class="input-group">
                                    <input asp-for="Price" class="form-control" type="number" min="0" placeholder="35000" id="Price" />
                                    <span class="input-group-text">đ</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label required-label">Danh mục</label>
                                <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                                        class="form-select" id="CategoryId">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label">Mô tả sản phẩm</label>
                                <textarea asp-for="Description" class="form-control" rows="4"
                                          placeholder="Mô tả chi tiết về sản phẩm thực phẩm sạch..." id="Description"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Hình ảnh sản phẩm</label>
                                <input type="file" name="ImageFile" class="form-control" accept="image/*"
                                       id="ImageFile" onchange="previewImage(this)" />
                                <div class="form-text">Định dạng: JPG, PNG, WEBP. Tối đa 5MB.</div>
                                <div id="imagePreview" class="mt-2" style="display:none;">
                                    <img id="previewImg" src="" alt="Preview" class="img-preview" />
                                </div>
                            </div>
                        </div>

                        <div class="form-actions mt-4">
                            <button type="submit" class="btn btn-admin-submit" id="submitAddBtn">
                                <i class="fa-solid fa-floppy-disk me-2"></i>Lưu sản phẩm
                            </button>
                            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                               class="btn btn-admin-cancel">
                                <i class="fa-solid fa-xmark me-2"></i>Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-card { background: white; border-radius: 16px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); overflow: hidden; }
    .form-card-header {
        background: linear-gradient(135deg, #1b5e20, #2e7d32);
        color: white; font-size: 1.2rem; font-weight: 700; padding: 20px 30px;
    }
    .form-card-body { padding: 30px; }
    .form-label { font-weight: 600; color: #2e7d32; font-size: 0.88rem; margin-bottom: 6px; }
    .required-label::after { content: " *"; color: #c62828; }
    .form-control, .form-select {
        border: 1.5px solid #c8e6c9; border-radius: 10px;
        padding: 11px 15px; font-size: 0.92rem; transition: all 0.3s;
    }
    .form-control:focus, .form-select:focus {
        border-color: #2e7d32; box-shadow: 0 0 0 3px rgba(46,125,50,0.12); outline: none;
    }
    .btn-admin-submit {
        background: linear-gradient(135deg, #2e7d32, #43a047);
        color: white; border: none; border-radius: 10px; padding: 12px 30px;
        font-weight: 700; font-size: 0.95rem; transition: all 0.3s;
    }
    .btn-admin-submit:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(46,125,50,0.35); color: white; }
    .btn-admin-cancel {
        background: #f5f5f5; color: #555; border: 1.5px solid #ddd;
        border-radius: 10px; padding: 12px 24px; font-weight: 600; font-size: 0.95rem; text-decoration: none;
        display: inline-flex; align-items: center; transition: all 0.2s;
    }
    .btn-admin-cancel:hover { background: #eeeeee; color: #333; }
    .form-actions { display: flex; gap: 12px; align-items: center; }
    .img-preview { max-width: 200px; max-height: 200px; object-fit: cover; border-radius: 10px; border: 2px solid #c8e6c9; }
    .input-group-text { background: #e8f5e9; border: 1.5px solid #c8e6c9; color: #2e7d32; font-weight: 700; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('imagePreview').style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
