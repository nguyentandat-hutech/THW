@model WebThucPhamSach.Models.Product
@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="d-flex align-items-center mb-4">
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-plus-circle text-success me-2"></i>Thêm sản phẩm mới</h4>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="admin-card p-4">
            <form asp-area="Admin" asp-controller="Product" asp-action="Add" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-600"></label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-600"></label>
                        <div class="input-group">
                            <input asp-for="Price" class="form-control" placeholder="35000" />
                            <span class="input-group-text">₫</span>
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label fw-600"></label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-600"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"
                              placeholder="Mô tả nguồn gốc, chứng nhận, đặc điểm sản phẩm..."></textarea>
                </div>

                <div class="mb-4">
                    <label for="imageFile" class="form-label fw-600">Hình ảnh sản phẩm</label>
                    <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" />
                    <small class="text-muted">Chấp nhận: JPG, PNG, WebP (tối đa 5MB)</small>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-check-circle me-1"></i> Lưu sản phẩm
                    </button>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                       class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Preview ảnh -->
    <div class="col-lg-4">
        <div class="admin-card p-4 text-center">
            <p class="text-muted small mb-2">Preview ảnh</p>
            <img id="imgPreview" src="#" alt="Preview"
                 class="img-fluid rounded d-none" style="max-height:200px;object-fit:cover;" />
            <div id="imgPlaceholder" class="rounded bg-light d-flex align-items-center justify-content-center"
                 style="height:200px;">
                <div class="text-muted">
                    <i class="bi bi-image fs-1 d-block mb-2"></i>
                    <small>Chọn ảnh để xem trước</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('imageFile').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(ev) {
                    document.getElementById('imgPreview').src = ev.target.result;
                    document.getElementById('imgPreview').classList.remove('d-none');
                    document.getElementById('imgPlaceholder').classList.add('d-none');
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
