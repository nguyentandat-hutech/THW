@model IEnumerable<WebThucPhamSach.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var categories = ViewBag.Categories as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-box-seam text-primary me-2"></i>Danh sách sản phẩm</h4>
        <p class="text-muted mb-0">Tổng: <strong>@Model.Count()</strong> sản phẩm</p>
    </div>
    <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i> Thêm sản phẩm
    </a>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th style="width:60px">STT</th>
                    <th style="width:80px">Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th>Giá</th>
                    <th style="width:160px" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            Chưa có sản phẩm nào
                        </td>
                    </tr>
                }
                @{ int stt = 1; }
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="text-muted">@(stt++)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="~/images/@p.ImageUrl" alt="@p.Name"
                                     class="rounded" style="width:50px;height:50px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                     style="width:50px;height:50px;">
                                    <i class="bi bi-image text-muted"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <div class="fw-600">@p.Name</div>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <small class="text-muted">
                                    @(p.Description.Length > 60 ? p.Description[..60] + "..." : p.Description)
                                </small>
                            }
                        </td>
                        <td>
                            <span class="badge bg-success-subtle text-success border border-success-subtle">
                                @(categories.TryGetValue(p.CategoryId, out var catName) ? catName : "N/A")
                            </span>
                        </td>
                        <td class="fw-bold text-danger">
                            @p.Price.ToString("N0") ₫
                        </td>
                        <td class="text-center">
                            <a asp-area="Admin" asp-controller="Product" asp-action="Update"
                               asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-area="Admin" asp-controller="Product" asp-action="Delete"
                               asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
