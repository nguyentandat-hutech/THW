<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel | Organic Food Store</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />

    <style>
        body { font-family: 'Nunito', sans-serif; background: #f0f2f5; }

        /* Sidebar */
        .admin-sidebar {
            width: 260px;
            min-height: 100vh;
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            position: fixed;
            top: 0; left: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 15px rgba(0,0,0,0.3);
        }
        .admin-sidebar .sidebar-brand {
            padding: 1.5rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .admin-sidebar .sidebar-brand h5 {
            color: #4ade80;
            font-weight: 800;
            margin: 0;
            font-size: 1rem;
        }
        .admin-sidebar .sidebar-brand small {
            color: rgba(255,255,255,0.5);
            font-size: 0.75rem;
        }
        .sidebar-nav { padding: 1rem 0; flex: 1; }
        .sidebar-nav .nav-section {
            padding: 0.5rem 1.25rem 0.25rem;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.3);
            font-weight: 700;
        }
        .sidebar-nav .nav-link {
            color: rgba(255,255,255,0.7);
            padding: 0.65rem 1.25rem;
            border-radius: 0;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }
        .sidebar-nav .nav-link:hover,
        .sidebar-nav .nav-link.active {
            color: #fff;
            background: rgba(255,255,255,0.08);
            border-left-color: #4ade80;
        }
        .sidebar-nav .nav-link i { font-size: 1.1rem; width: 20px; text-align: center; }

        /* Main content */
        .admin-main {
            margin-left: 260px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .admin-topbar {
            background: #fff;
            padding: 0.875rem 1.5rem;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .admin-topbar .page-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0;
        }
        .admin-content { padding: 1.5rem; flex: 1; }

        /* Cards */
        .admin-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            border: none;
        }
        .admin-card .card-header {
            background: linear-gradient(135deg, #1a1a2e, #0f3460);
            color: white;
            border-radius: 12px 12px 0 0 !important;
            padding: 1rem 1.5rem;
            font-weight: 700;
        }

        /* Buttons */
        .btn-admin-primary { background: #0f3460; border-color: #0f3460; color: #fff; }
        .btn-admin-primary:hover { background: #1a1a2e; border-color: #1a1a2e; color: #fff; }

        /* Table */
        .admin-table { border-collapse: separate; border-spacing: 0; }
        .admin-table thead th {
            background: #f8fafc;
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            border-bottom: 2px solid #e2e8f0;
            padding: 0.875rem 1rem;
        }
        .admin-table tbody td {
            padding: 0.875rem 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            font-size: 0.9rem;
        }
        .admin-table tbody tr:hover { background: #f8fafc; }

        /* Badge */
        .badge-admin { font-size: 0.7rem; padding: 0.35em 0.7em; }
    </style>
</head>
<body>

    <!-- ==================== SIDEBAR ==================== -->
    <aside class="admin-sidebar">
        <div class="sidebar-brand">
            <div class="d-flex align-items-center gap-2 mb-1">
                <i class="bi bi-shield-fill-check text-success fs-4"></i>
                <h5>Admin Panel</h5>
            </div>
            <small>Organic Food Store</small>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">Tổng quan</div>
            <a class="nav-link" asp-area="Admin" asp-controller="Product" asp-action="Index">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <div class="nav-section mt-2">Quản lý</div>
            <a class="nav-link" asp-area="Admin" asp-controller="Product" asp-action="Index">
                <i class="bi bi-box-seam"></i> Sản phẩm
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Category" asp-action="Index">
                <i class="bi bi-tags"></i> Danh mục
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Order" asp-action="Index">
                <i class="bi bi-receipt"></i> Đơn hàng
            </a>

            <div class="nav-section mt-2">Hệ thống</div>
            <a class="nav-link" asp-controller="Product" asp-action="Index" asp-area="">
                <i class="bi bi-shop"></i> Xem trang khách
            </a>
        </nav>

        <!-- Thông tin người dùng đang đăng nhập -->
        <div class="p-3 border-top border-secondary">
            <div class="d-flex align-items-center gap-2 mb-2">
                <div class="rounded-circle bg-success d-flex align-items-center justify-content-center"
                     style="width:36px;height:36px;">
                    <i class="bi bi-person-fill text-white"></i>
                </div>
                <div>
                    <div class="text-white fw-600" style="font-size:0.85rem;">
                        @UserManager.GetUserName(User)
                    </div>
                    <span class="badge bg-success badge-admin">Admin</span>
                </div>
            </div>
            <form asp-controller="Account" asp-action="Logout" asp-area="" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-light w-100">
                    <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                </button>
            </form>
        </div>
    </aside>

    <!-- ==================== MAIN CONTENT ==================== -->
    <div class="admin-main">
        <!-- Topbar -->
        <div class="admin-topbar">
            <h6 class="page-title">
                <i class="bi bi-leaf text-success me-2"></i>
                @(ViewData["Title"] ?? "Admin Panel")
            </h6>
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-danger">
                    <i class="bi bi-shield-fill me-1"></i>Admin Mode
                </span>
                <a asp-controller="Product" asp-action="Index" asp-area=""
                   class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Về trang chủ
                </a>
            </div>
        </div>

        <!-- Alert thông báo -->
        <div class="px-4 pt-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>

        <!-- Nội dung trang -->
        <main class="admin-content">
            @RenderBody()
        </main>

        <footer class="text-center text-muted py-3" style="font-size:0.8rem;border-top:1px solid #e5e7eb;">
            &copy; @DateTime.Now.Year Organic Food Store — Admin Panel
        </footer>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
